{% comment %}
  Nourish Her - Sticky Bottom CTA
  Fixed bottom bar that appears after scrolling past hero.
  Settings are passed in from the parent section (see sections/nh-offer.liquid).
    - product_title, subscription_price, onetime_price, cta_text, cta_link, enabled
{% endcomment %}

{%- assign _enabled = enabled -%}
{%- if _enabled == blank -%}{%- assign _enabled = true -%}{%- endif -%}
{%- if _enabled == false -%}{%- comment -%}Disabled via section settings{%- endcomment -%}
{%- else -%}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

<div class="nh-sticky-bottom-cta" id="nhStickyBottomCta">
  <div class="nh-sticky-bottom-info">
    <div class="nh-sticky-bottom-name">{{ product_title | default: 'Nourish Her™' }}</div>
    <div class="nh-sticky-bottom-trust">
      {%- assign _t1 = trust_1_text | default: '30 Day Money Back Guarantee' -%}
      {%- assign _t2 = trust_2_text | default: 'Free Shipping' -%}
      {% if _t1 != blank %}
        <span class="nh-sticky-bottom-trust-item">
          <span class="nh-sticky-bottom-trust-icon" aria-hidden="true">
            {% if trust_1_icon != blank %}
              {{ trust_1_icon | image_url: width: 60 | image_tag: alt: '', loading: 'lazy', class: 'nh-sticky-bottom-trust-icon-img' }}
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
            {% endif %}
          </span>
          <span class="nh-sticky-bottom-trust-text">{{ _t1 }}</span>
        </span>
      {% endif %}
      {% if _t2 != blank %}
        <span class="nh-sticky-bottom-trust-item">
          <span class="nh-sticky-bottom-trust-icon" aria-hidden="true">
            {% if trust_2_icon != blank %}
              {{ trust_2_icon | image_url: width: 60 | image_tag: alt: '', loading: 'lazy', class: 'nh-sticky-bottom-trust-icon-img' }}
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            {% endif %}
          </span>
          <span class="nh-sticky-bottom-trust-text">{{ _t2 }}</span>
        </span>
      {% endif %}
    </div>
  </div>
  {%- assign _cta_icon_size = cta_icon_size | default: 20 -%}
  {%- capture _cta_inner -%}
    <span class="nh-sticky-bottom-btn-label">{{ cta_text | default: 'Shop Now' }}</span>
    {% if cta_icon != blank %}
      <span class="nh-sticky-bottom-btn-icon" style="width: {{ _cta_icon_size }}px; height: {{ _cta_icon_size }}px;" aria-hidden="true">
        {{ cta_icon | image_url: width: 80 | image_tag:
            alt: '',
            loading: 'lazy',
            class: 'nh-sticky-bottom-btn-icon-img'
        }}
      </span>
    {% endif %}
  {%- endcapture -%}
  {% if cta_link != blank %}
    <a class="nh-sticky-bottom-btn" href="{{ cta_link }}">{{ _cta_inner }}</a>
  {% else %}
    <button class="nh-sticky-bottom-btn" type="button" onclick="(function(){var t=document.querySelector('.nh-offer-section')||document.getElementById('nh-offer');if(t){t.scrollIntoView({behavior:'smooth',block:'start'});}})()">
      {{ _cta_inner }}
    </button>
  {% endif %}
</div>

<script>
  // Sticky bottom CTA visibility.
  // Remains hidden until the user has scrolled PAST the Spotlight section.
  // The trigger is the first Shopify section that appears AFTER Spotlight
  // (and is not Hero, Spotlight, or the sticky itself). This avoids matching
  // header/announcement sections that sit above Hero in the DOM.
  // CTA click-scroll behavior is handled globally by snippets/nh-cta-scroll.liquid.
  (function() {
    const cta = document.getElementById('nhStickyBottomCta');
    if (!cta) return;

    function findTrigger() {
      const sections = Array.from(document.querySelectorAll('[id^="shopify-section-"]'));
      // Find the last section containing Spotlight (the marker).
      // If Spotlight does not exist, fall back to Hero as the marker.
      let markerIdx = -1;
      for (let i = sections.length - 1; i >= 0; i--) {
        if (sections[i].querySelector('.nh-spotlight')) { markerIdx = i; break; }
      }
      if (markerIdx < 0) {
        for (let i = sections.length - 1; i >= 0; i--) {
          if (sections[i].querySelector('.nh-hero')) { markerIdx = i; break; }
        }
      }
      // Walk forward from marker, return the first qualifying section.
      for (let i = markerIdx + 1; i < sections.length; i++) {
        const s = sections[i];
        if (s.querySelector('.nh-sticky-bottom-cta')) continue;
        if (s.querySelector('.nh-hero')) continue;
        if (s.querySelector('.nh-spotlight')) continue;
        return s;
      }
      return null;
    }
    let trigger = findTrigger();

    const SHOW_OFFSET = 0.9;
    function check() {
      if (!trigger) {
        trigger = findTrigger();
        if (!trigger) { cta.classList.remove('nh-visible'); return; }
      }
      const rect = trigger.getBoundingClientRect();
      if (rect.top <= window.innerHeight * SHOW_OFFSET) {
        cta.classList.add('nh-visible');
      } else {
        cta.classList.remove('nh-visible');
      }
    }
    window.addEventListener('scroll', check, { passive: true });
    window.addEventListener('resize', check);
    check();
    setTimeout(check, 250);
    setTimeout(check, 1000);
  })();
</script>

{%- endif -%}
