{% comment %}
  Nourish Her - Sticky Bottom CTA
  Fixed bottom bar that appears after scrolling past hero.
  Settings are passed in from the parent section (see sections/nh-offer.liquid).
    - product_title, subscription_price, onetime_price, cta_text, cta_link, enabled
{% endcomment %}

{%- assign _enabled = enabled -%}
{%- if _enabled == blank -%}{%- assign _enabled = true -%}{%- endif -%}
{%- if _enabled == false -%}{%- comment -%}Disabled via section settings{%- endcomment -%}
{%- else -%}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

<div class="nh-sticky-bottom-cta" id="nhStickyBottomCta">
  <div class="nh-sticky-bottom-info">
    <div class="nh-sticky-bottom-name">{{ product_title | default: 'Nourish Her™' }}</div>
    <div class="nh-sticky-bottom-price">
      Subscribe from <strong>{{ subscription_price | default: '£34.99/mo' }}</strong> · One-time <strong>{{ onetime_price | default: '£44.99' }}</strong>
    </div>
  </div>
  {% if cta_link != blank %}
    <a class="nh-sticky-bottom-btn" href="{{ cta_link }}">{{ cta_text | default: 'Shop Now' }}</a>
  {% else %}
    <button class="nh-sticky-bottom-btn" type="button" onclick="var t=document.getElementById('nh-offer');if(t){t.scrollIntoView({behavior:'smooth'});}">
      {{ cta_text | default: 'Shop Now' }}
    </button>
  {% endif %}
</div>

<script>
  // Sticky bottom CTA visibility - hidden in hero; appears once user reaches the Spotlight (second) section and stays visible thereafter.
  (function() {
    const cta = document.getElementById('nhStickyBottomCta');
    if (!cta) return;

    // Trigger element: top of the Spotlight section (the 2nd section on the page).
    // Fallback: first non-hero section if .nh-spotlight isn't present.
    const trigger = document.querySelector('.nh-spotlight')
                 || document.querySelector('main section:not(.nh-hero)')
                 || document.querySelector('.nh-hero + *');
    if (!trigger) return;

    const SHOW_OFFSET = 0.9; // show when trigger's top enters top 90% of viewport

    function check() {
      const rect = trigger.getBoundingClientRect();
      if (rect.top <= window.innerHeight * SHOW_OFFSET) {
        cta.classList.add('nh-visible');
      } else {
        cta.classList.remove('nh-visible');
      }
    }

    window.addEventListener('scroll', check, { passive: true });
    window.addEventListener('resize', check);
    // Initial check (also after a tick so async-rendered sections are in place)
    check();
    setTimeout(check, 250);
  })();
</script>

{%- endif -%}
