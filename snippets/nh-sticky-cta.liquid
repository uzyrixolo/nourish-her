{% comment %}
  Nourish Her - Sticky Bottom CTA
  Fixed bottom bar that appears after scrolling past hero.
  Settings are passed in from the parent section (see sections/nh-offer.liquid).
    - product_title, subscription_price, onetime_price, cta_text, cta_link, enabled
{% endcomment %}

{%- assign _enabled = enabled -%}
{%- if _enabled == blank -%}{%- assign _enabled = true -%}{%- endif -%}
{%- if _enabled == false -%}{%- comment -%}Disabled via section settings{%- endcomment -%}
{%- else -%}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

<div class="nh-sticky-bottom-cta" id="nhStickyBottomCta">
  <div class="nh-sticky-bottom-info">
    <div class="nh-sticky-bottom-name">{{ product_title | default: 'Nourish Her™' }}</div>
    <div class="nh-sticky-bottom-price">
      Subscribe from <strong>{{ subscription_price | default: '£34.99/mo' }}</strong> · One-time <strong>{{ onetime_price | default: '£44.99' }}</strong>
    </div>
  </div>
  {% if cta_link != blank %}
    <a class="nh-sticky-bottom-btn" href="{{ cta_link }}">{{ cta_text | default: 'Shop Now' }}</a>
  {% else %}
    <button class="nh-sticky-bottom-btn" type="button" onclick="(function(){var t=document.querySelector('.nh-offer-section')||document.getElementById('nh-offer');if(t){t.scrollIntoView({behavior:'smooth',block:'start'});}})()">
      {{ cta_text | default: 'Shop Now' }}
    </button>
  {% endif %}
</div>

<script>
  // Sticky bottom CTA + global CTA scroll-to-offer behavior.
  (function() {
    const offerEl = function() {
      return document.querySelector('.nh-offer-section') || document.getElementById('nh-offer');
    };

    // ---------- 1. Sticky bar visibility ----------
    // Hidden on Hero AND Spotlight. Appears only from the 3rd section onwards and stays visible.
    const cta = document.getElementById('nhStickyBottomCta');
    if (cta) {
      // Pick the trigger = first section that is NOT hero AND NOT spotlight.
      // Prefer Shopify's section wrappers so we're order-independent.
      function findTrigger() {
        const sections = Array.from(document.querySelectorAll('[id^="shopify-section-"]'));
        for (const s of sections) {
          if (s.querySelector('.nh-hero')) continue;
          if (s.querySelector('.nh-spotlight')) continue;
          // Skip the sticky bar section itself
          if (s.querySelector('.nh-sticky-bottom-cta')) continue;
          return s;
        }
        // Fallback: any element immediately after .nh-spotlight / .nh-hero
        return document.querySelector('.nh-spotlight ~ *') || document.querySelector('.nh-hero ~ *');
      }
      let trigger = findTrigger();

      const SHOW_OFFSET = 0.9; // show when trigger's top enters top 90% of viewport
      function check() {
        if (!trigger) { trigger = findTrigger(); if (!trigger) return; }
        const rect = trigger.getBoundingClientRect();
        if (rect.top <= window.innerHeight * SHOW_OFFSET) {
          cta.classList.add('nh-visible');
        } else {
          cta.classList.remove('nh-visible');
        }
      }
      window.addEventListener('scroll', check, { passive: true });
      window.addEventListener('resize', check);
      check();
      setTimeout(check, 250);
      setTimeout(check, 1000);
    }

    // ---------- 2. Global CTA -> scroll to Offer section ----------
    // Intercepts clicks on any NH CTA button/link so they smooth-scroll to the Offer section
    // instead of following their original link. Excludes: form submit buttons (e.g. Add to Cart)
    // and CTAs that are already inside the Offer section.
    const CTA_SELECTOR = [
      '.nh-btn-primary',
      '.nh-spotlight-cta',
      '.nh-sticky-bottom-btn',
      'a[href="#nh-offer"]',
      'a[href$="#nh-offer"]',
      '[data-nh-scroll="offer"]'
    ].join(',');

    document.addEventListener('click', function(e) {
      const el = e.target.closest(CTA_SELECTOR);
      if (!el) return;
      // Don't hijack form submission (Add to Cart)
      if (el.tagName === 'BUTTON' && el.getAttribute('type') === 'submit') return;
      // Don't hijack CTAs that live inside the Offer section itself
      const inOffer = el.closest('.nh-offer-section') || el.closest('#nh-offer');
      if (inOffer) return;
      const target = offerEl();
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, true);
  })();
</script>

{%- endif -%}
