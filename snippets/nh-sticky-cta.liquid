{% comment %}
  Nourish Her - Sticky Bottom CTA
  Fixed bottom bar — visibility is controlled by the Hero section's IntersectionObserver.
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

<div class="nh-sticky-bottom-cta" id="nhStickyBottomCta">
  <div class="nh-sticky-bottom-info">
    <div class="nh-sticky-bottom-name">{{ product.title | default: 'Nourish Her™' }}</div>
    <div class="nh-sticky-bottom-price">
      Subscribe from <strong>{{ subscription_price | default: '£34.99/mo' }}</strong> · One-time <strong>{{ onetime_price | default: '£44.99' }}</strong>
    </div>
  </div>
  <button class="nh-sticky-bottom-btn" onclick="document.getElementById('nh-offer') ? document.getElementById('nh-offer').scrollIntoView({behavior:'smooth'}) : window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'})">
    {{ cta_text | default: 'Shop Now' }}
  </button>
</div>
