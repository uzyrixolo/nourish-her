{% comment %}
  Renders a single NH Spotlight block's inner content.
  Params:
    - block (required): the current block from section.blocks
    - section_settings (required): section.settings (for color fallbacks)
    - order (required): integer for CSS `order` (used to re-sort on mobile)
{% endcomment %}

{% assign col_class = block.settings.column | default: 'left' %}
{% assign vis_class = '' %}
{% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
{% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}

<div class="nh-spotlight-block nh-spotlight-block--{{ col_class }} nh-spotlight-block--{{ block.type }}{{ vis_class }}" style="order: {{ order }};" {{ block.shopify_attributes }}>
  {% case block.type %}

    {% when 'announcement' %}
      <div class="nh-spotlight-announce"
           style="background: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }}; font-size: {{ block.settings.font_size }}px; --nh-fs-m: {{ block.settings.font_size_mobile | default: block.settings.font_size }}px; justify-content: {{ block.settings.align | default: 'center' }};">
        {% if block.settings.icon != blank %}
          <span class="nh-spotlight-announce-icon">{{ block.settings.icon }}</span>
        {% endif %}
        <span class="nh-spotlight-announce-text">{{ block.settings.text }}</span>
      </div>

    {% when 'eyebrow' %}
      {% assign _color = block.settings.color | default: section_settings.accent_color %}
      <p class="nh-spotlight-eyebrow"
         style="color: {{ _color }}; font-size: {{ block.settings.font_size }}px; --nh-fs-m: {{ block.settings.font_size_mobile | default: block.settings.font_size }}px; letter-spacing: {{ block.settings.letter_spacing | times: 0.01 }}em;">
        {{ block.settings.text }}
      </p>

    {% when 'heading' %}
      {% assign _color = block.settings.color | default: section_settings.heading_color %}
      {% assign _accent = block.settings.accent_color | default: section_settings.accent_color %}
      <h2 class="nh-spotlight-heading"
          style="color: {{ _color }}; font-size: {{ block.settings.font_size }}px; --nh-fs-m: {{ block.settings.font_size_mobile | default: block.settings.font_size }}px; --nh-heading-accent: {{ _accent }};">
        {{ block.settings.heading }}
      </h2>

    {% when 'pills' %}
      <div class="nh-spotlight-pills" style="justify-content: {{ block.settings.align | default: 'center' }};">
        {% for i in (1..6) %}
          {% capture key %}pill_{{ i }}{% endcapture %}
          {% assign pill_text = block.settings[key] %}
          {% if pill_text != blank %}
            <span class="nh-spotlight-pill"
                  style="background: {{ block.settings.pill_bg }}; color: {{ block.settings.pill_text }}; border-color: {{ block.settings.pill_border }};">
              <span class="nh-spotlight-pill-check" style="background: {{ block.settings.check_color }};">✓</span>
              <span class="nh-spotlight-pill-text">{{ pill_text }}</span>
            </span>
          {% endif %}
        {% endfor %}
      </div>

    {% when 'image' %}
      {% if block.settings.image != blank %}
        <div class="nh-spotlight-image"
             style="max-width: {{ block.settings.max_width }}px; margin-left: {% if block.settings.align == 'left' %}0{% else %}auto{% endif %}; margin-right: {% if block.settings.align == 'right' %}0{% else %}auto{% endif %};">
          {{ block.settings.image | image_url: width: 1400 | image_tag: alt: block.settings.image_alt, loading: 'lazy', widths: '400,600,800,1000,1200,1400', sizes: '(max-width: 768px) 90vw, 520px' }}
        </div>
      {% endif %}

    {% when 'cta' %}
      {%- assign _cta_radius = block.settings.border_radius | default: 6 -%}
      {%- assign _cta_icon_size = block.settings.icon_size | default: 32 -%}
      {%- capture _cta_inner -%}
        <div class="nh-spotlight-cta-text">
          {% if block.settings.heading != blank %}<div class="nh-spotlight-cta-heading">{{ block.settings.heading }}</div>{% endif %}
          {% if block.settings.subtext != blank %}<div class="nh-spotlight-cta-subtext">{{ block.settings.subtext }}</div>{% endif %}
        </div>
        {% if block.settings.icon_image != blank %}
          <div class="nh-spotlight-cta-icon nh-spotlight-cta-icon--image" style="width: {{ _cta_icon_size }}px; height: {{ _cta_icon_size }}px;">
            {{ block.settings.icon_image | image_url: width: 160 | image_tag: alt: block.settings.heading, loading: 'lazy', widths: '40,80,120,160' }}
          </div>
        {% elsif block.settings.icon != blank %}
          <div class="nh-spotlight-cta-icon" style="font-size: {{ _cta_icon_size | times: 0.9 }}px;">{{ block.settings.icon }}</div>
        {% endif %}
      {%- endcapture -%}
      {% if block.settings.link != blank %}
        <a class="nh-spotlight-cta" href="{{ block.settings.link }}"
           style="background: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }}; border-radius: {{ _cta_radius }}px;">
          {{ _cta_inner }}
        </a>
      {% else %}
        <div class="nh-spotlight-cta"
             style="background: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }}; border-radius: {{ _cta_radius }}px;">
          {{ _cta_inner }}
        </div>
      {% endif %}

    {% when 'reviews' %}
      <div class="nh-spotlight-reviews" style="justify-content: {{ block.settings.align | default: 'center' }};">
        <span class="nh-spotlight-stars" aria-hidden="true" style="color: {{ block.settings.star_color | default: '#f5b826' }};">★★★★★</span>
        {% if block.settings.rating != blank %}<span class="nh-spotlight-rating">Rated {{ block.settings.rating }} / 5.0</span>{% endif %}
        {% if block.settings.reviews_count != blank %}
          <span class="nh-spotlight-divider">|</span>
          {% if block.settings.reviews_link != blank %}
            <a class="nh-spotlight-reviews-link" href="{{ block.settings.reviews_link }}">{{ block.settings.reviews_count }}</a>
          {% else %}
            <span class="nh-spotlight-reviews-link">{{ block.settings.reviews_count }}</span>
          {% endif %}
        {% endif %}
      </div>

    {% when 'quote' %}
      {%- assign _quote_bg = block.settings.bg_color | default: '#ffffff' -%}
      <div class="nh-spotlight-quote"
           style="background: {{ _quote_bg }}; border-color: {{ block.settings.border_color }};">
        <span class="nh-spotlight-quote-mark" aria-hidden="true"
              style="color: {{ block.settings.quote_mark_color | default: section_settings.accent_color }}; background: {{ _quote_bg }};">&ldquo;</span>
        <p class="nh-spotlight-quote-text" style="color: {{ block.settings.text_color }};">{{ block.settings.text }}</p>
        {% if block.settings.author != blank %}<p class="nh-spotlight-quote-author">&mdash; {{ block.settings.author }}</p>{% endif %}
      </div>

  {% endcase %}
</div>
