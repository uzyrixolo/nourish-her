{% doc %}
  @prompt
    Create a standalone Shopify hero section that matches this exact layout: a full-width background image with soft, warm overlay and left-aligned content; at the top, include a small rounded label/badge (editable text); below it, a large headline split into two styles — first line bold sans-serif, second line italic/script-style (both fully editable); underneath, add a 5-star rating row with accompanying editable text (e.g. “Chosen by 12,000+ mindful kitchens”); then a short paragraph description; followed by a prominent rounded CTA button with editable text, link, colours, and optional arrow icon inside the button; below the button include a small icon + text line (e.g. shipping message);  all colours, fonts, spacing, alignment, overlay opacity, and image must be fully customisable in the theme editor; ensure the section is responsive with clean stacking on mobile; do not include any navigation arrows or sliders., Make the background image full width, I want to be able to align the content at the top, currently it is aligned in the centre
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    min-height: {{ block.settings.section_height }}px;
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    overflow: hidden;
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
    {% if block.settings.text_alignment == 'left' %}
      margin-right: auto;
    {% elsif block.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif block.settings.text_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .ai-hero-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    background-color: {{ block.settings.badge_background_color }};
    color: {{ block.settings.badge_text_color }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    margin-bottom: {{ block.settings.badge_spacing }}px;
    text-transform: {{ block.settings.badge_text_transform }};
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-hero-heading-line1-{{ ai_gen_id }} {
    display: block;
    font-family: {{ block.settings.heading_line1_font.family }}, {{ block.settings.heading_line1_font.fallback_families }};
    font-weight: {{ block.settings.heading_line1_font.weight }};
    font-size: {{ block.settings.heading_line1_size }}px;
    line-height: 1.1;
    color: {{ block.settings.heading_line1_color }};
    margin-bottom: {{ block.settings.heading_line_spacing }}px;
  }

  .ai-hero-heading-line2-{{ ai_gen_id }} {
    display: block;
    font-family: {{ block.settings.heading_line2_font.family }}, {{ block.settings.heading_line2_font.fallback_families }};
    font-weight: {{ block.settings.heading_line2_font.weight }};
    font-style: {{ block.settings.heading_line2_font.style }};
    font-size: {{ block.settings.heading_line2_size }}px;
    line-height: 1.1;
    color: {{ block.settings.heading_line2_color }};
  }

  .ai-hero-rating-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: {{ block.settings.rating_spacing }}px;
    {% if block.settings.text_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-hero-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-hero-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-hero-rating-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.rating_text_size }}px;
    color: {{ block.settings.rating_text_color }};
  }

  .ai-hero-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.description_color }};
    margin-bottom: {{ block.settings.description_spacing }}px;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: {{ block.settings.button_spacing }}px;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-button-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    transition: transform 0.3s ease;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover .ai-hero-button-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-hero-info-line-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.info_text_size }}px;
    color: {{ block.settings.info_text_color }};
    {% if block.settings.text_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-hero-info-icon-{{ ai_gen_id }} {
    width: {{ block.settings.info_icon_size }}px;
    height: {{ block.settings.info_icon_size }}px;
    stroke: {{ block.settings.info_icon_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-section-{{ ai_gen_id }} {
      min-height: {{ block.settings.section_height_mobile }}px;
      align-items: {{ block.settings.vertical_alignment_mobile }};
    }

    .ai-hero-content-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment_mobile }};
      {% if block.settings.text_alignment_mobile == 'left' %}
        margin-right: auto;
        margin-left: 0;
      {% elsif block.settings.text_alignment_mobile == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif block.settings.text_alignment_mobile == 'right' %}
        margin-left: auto;
        margin-right: 0;
      {% endif %}
    }

    .ai-hero-heading-line1-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_line1_size_mobile }}px;
    }

    .ai-hero-heading-line2-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_line2_size_mobile }}px;
    }

    .ai-hero-rating-wrapper-{{ ai_gen_id }} {
      {% if block.settings.text_alignment_mobile == 'left' %}
        justify-content: flex-start;
      {% elsif block.settings.text_alignment_mobile == 'center' %}
        justify-content: center;
      {% elsif block.settings.text_alignment_mobile == 'right' %}
        justify-content: flex-end;
      {% endif %}
    }

    .ai-hero-info-line-{{ ai_gen_id }} {
      {% if block.settings.text_alignment_mobile == 'left' %}
        justify-content: flex-start;
      {% elsif block.settings.text_alignment_mobile == 'center' %}
        justify-content: center;
      {% elsif block.settings.text_alignment_mobile == 'right' %}
        justify-content: flex-end;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-content-wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.badge_text != blank %}
        <div class="ai-hero-badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      <div class="ai-hero-heading-{{ ai_gen_id }}">
        {% if block.settings.heading_line1 != blank %}
          <span class="ai-hero-heading-line1-{{ ai_gen_id }}">
            {{ block.settings.heading_line1 }}
          </span>
        {% endif %}
        {% if block.settings.heading_line2 != blank %}
          <span class="ai-hero-heading-line2-{{ ai_gen_id }}">
            {{ block.settings.heading_line2 }}
          </span>
        {% endif %}
      </div>

      {% if block.settings.show_rating %}
        <div class="ai-hero-rating-wrapper-{{ ai_gen_id }}">
          <div class="ai-hero-stars-{{ ai_gen_id }}">
            {% for i in (1..5) %}
              <svg class="ai-hero-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endfor %}
          </div>
          {% if block.settings.rating_text != blank %}
            <span class="ai-hero-rating-text-{{ ai_gen_id }}">
              {{ block.settings.rating_text }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-hero-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-hero-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
          {% if block.settings.show_button_arrow %}
            <svg class="ai-hero-button-arrow-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% endif %}
        </a>
      {% endif %}

      {% if block.settings.info_text != blank %}
        <div class="ai-hero-info-line-{{ ai_gen_id }}">
          {% if block.settings.show_info_icon %}
            <svg class="ai-hero-info-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10m-8-10v10l8 4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% endif %}
          {{ block.settings.info_text }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero section",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Section dimensions"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop height",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Mobile height",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Desktop top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Desktop horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal_mobile",
      "label": "Mobile horizontal padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Content layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Desktop vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment_mobile",
      "label": "Mobile vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Desktop text alignment",
      "options": [
        {
          "value": "left",
