    },
    {
      "type": "font_picker",
      "id": "heading_line2_font",
      "label": "Font",
      "default": "dm_serif_display_i4"
    },
    {
      "type": "range",
      "id": "heading_line2_size",
      "label": "Desktop size",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "heading_line2_size_mobile",
      "label": "Mobile size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_line2_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_line_spacing",
      "label": "Line spacing",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Bottom spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
