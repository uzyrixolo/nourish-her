{% doc %}
  @prompt
    In the NH-Ingredients section, add a new image block that allows merchants to upload a custom image. The block should include customizable settings for image size (small, medium, large, or custom width/height in pixels) and aspect ratio (options like 1:1, 4:3, 16:9, 3:2, 2:3, or auto). The image should be responsive and display cleanly within the section layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .nh-custom-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0 auto;
  }

  .nh-custom-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    {% if block.settings.image_size == 'custom' %}
      max-width: {{ block.settings.custom_width }}px;
    {% elsif block.settings.image_size == 'small' %}
      max-width: 300px;
    {% elsif block.settings.image_size == 'medium' %}
      max-width: 600px;
    {% elsif block.settings.image_size == 'large' %}
      max-width: 900px;
    {% endif %}
    margin: 0 auto;
  }

  .nh-custom-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.aspect_ratio != 'auto' %}
      {% if block.settings.aspect_ratio == '1:1' %}
        padding-bottom: 100%;
      {% elsif block.settings.aspect_ratio == '4:3' %}
        padding-bottom: 75%;
      {% elsif block.settings.aspect_ratio == '16:9' %}
        padding-bottom: 56.25%;
      {% elsif block.settings.aspect_ratio == '3:2' %}
        padding-bottom: 66.67%;
      {% elsif block.settings.aspect_ratio == '2:3' %}
        padding-bottom: 150%;
      {% endif %}
    {% endif %}
  }

  .nh-custom-image-{{ ai_gen_id }} img {
    {% if block.settings.aspect_ratio != 'auto' %}
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    {% else %}
      width: 100%;
      height: auto;
      display: block;
    {% endif %}
    border-radius: {{ block.settings.border_radius }}px;
  }

  .nh-custom-image-placeholder-{{ ai_gen_id }} {
    {% if block.settings.aspect_ratio != 'auto' %}
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    {% else %}
      width: 100%;
      aspect-ratio: 16 / 9;
    {% endif %}
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .nh-custom-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .nh-custom-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .nh-custom-image-wrapper-{{ ai_gen_id }} {
      {% if block.settings.image_size == 'custom' %}
        max-width: 100%;
      {% endif %}
    }
  }
{% endstyle %}

<div class="nh-custom-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="nh-custom-image-wrapper-{{ ai_gen_id }}">
    <div class="nh-custom-image-container-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1800 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="nh-custom-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="nh-custom-image-empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom image",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "Image size",
      "options": [
        {
          "value": "small",
          "label": "Small (300px)"
        },
        {
          "value": "medium",
          "label": "Medium (600px)"
        },
        {
          "value": "large",
          "label": "Large (900px)"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom width",
      "min": 200,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "1:1",
          "label": "Square (1:1)"
        },
        {
          "value": "4:3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16:9",
          "label": "Widescreen (16:9)"
        },
        {
          "value": "3:2",
          "label": "Classic (3:2)"
        },
        {
          "value": "2:3",
          "label": "Portrait (2:3)"
        }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom image"
    }
  ]
}
{% endschema %}
