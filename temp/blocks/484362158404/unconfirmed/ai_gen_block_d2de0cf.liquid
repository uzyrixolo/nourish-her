{% doc %}
  @prompt
    Create me a comparison section consisting of a section heading, 2 column headings with an image above each one, and 5 columns. I want to be able to edit the colours and text for every part of the section., remove the first column that mentions price, quality etc so that it is simply 2 columns. Also i want to include a tick symbol on the left of each row of the first column, and a cross signal to the left of each row on the second column
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-comparison-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-comparison-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
  }

  .ai-comparison-header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    vertical-align: top;
    width: 50%;
  }

  .ai-comparison-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_width }}px;
    margin: 0 auto {{ block.settings.image_spacing }}px;
  }

  .ai-comparison-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-comparison-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-comparison-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-comparison-column-heading-{{ ai_gen_id }} {
    color: {{ block.settings.column_heading_color }};
    font-size: {{ block.settings.column_heading_size }}px;
    margin: 0;
    font-weight: 600;
  }

  .ai-comparison-row-{{ ai_gen_id }} {
    border-top: {{ block.settings.row_border_width }}px solid {{ block.settings.row_border_color }};
  }

  .ai-comparison-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    vertical-align: middle;
  }

  .ai-comparison-cell-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .ai-comparison-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-comparison-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-comparison-cell-text-{{ ai_gen_id }} {
    color: {{ block.settings.cell_text_color }};
    font-size: {{ block.settings.cell_text_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px;
    }

    .ai-comparison-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin-bottom: {{ block.settings.heading_spacing | times: 0.7 }}px;
    }

    .ai-comparison-image-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.image_width | times: 0.7 }}px;
      margin-bottom: {{ block.settings.image_spacing | times: 0.7 }}px;
    }

    .ai-comparison-column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.column_heading_size | times: 0.8 }}px;
    }

    .ai-comparison-cell-{{ ai_gen_id }} {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-cell-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.cell_text_size | times: 0.9 }}px;
    }

    .ai-comparison-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-comparison-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-comparison-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-comparison-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <table class="ai-comparison-table-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th class="ai-comparison-header-cell-{{ ai_gen_id }}">
            <div class="ai-comparison-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.column_1_image %}
                <img
                  src="{{ block.settings.column_1_image | image_url: width: 400 }}"
                  alt="{{ block.settings.column_1_image.alt | escape }}"
                  class="ai-comparison-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-comparison-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if block.settings.column_1_heading != blank %}
              <h3 class="ai-comparison-column-heading-{{ ai_gen_id }}">{{ block.settings.column_1_heading }}</h3>
            {% endif %}
          </th>
          <th class="ai-comparison-header-cell-{{ ai_gen_id }}">
            <div class="ai-comparison-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.column_2_image %}
                <img
                  src="{{ block.settings.column_2_image | image_url: width: 400 }}"
                  alt="{{ block.settings.column_2_image.alt | escape }}"
                  class="ai-comparison-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-comparison-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-2' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if block.settings.column_2_heading != blank %}
              <h3 class="ai-comparison-column-heading-{{ ai_gen_id }}">{{ block.settings.column_2_heading }}</h3>
            {% endif %}
          </th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..5) %}
          {% liquid
            assign col_1_text_key = 'row_' | append: i | append: '_col_1_text'
            assign col_2_text_key = 'row_' | append: i | append: '_col_2_text'
            
            assign col_1_text = block.settings[col_1_text_key]
            assign col_2_text = block.settings[col_2_text_key]
          %}
          
          <tr class="ai-comparison-row-{{ ai_gen_id }}">
            <td class="ai-comparison-cell-{{ ai_gen_id }}">
              <div class="ai-comparison-cell-content-{{ ai_gen_id }}">
                <div class="ai-comparison-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.tick_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <div class="ai-comparison-cell-text-{{ ai_gen_id }}">{{ col_1_text }}</div>
              </div>
            </td>
            <td class="ai-comparison-cell-{{ ai_gen_id }}">
              <div class="ai-comparison-cell-content-{{ ai_gen_id }}">
                <div class="ai-comparison-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.cross_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </div>
                <div class="ai-comparison-cell-text-{{ ai_gen_id }}">{{ col_2_text }}</div>
              </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% schema %}
{
  "name": "Comparison table",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Compare products"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "image_picker",
      "id": "column_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "column_1_heading",
      "label": "Heading",
      "default": "Product A"
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "image_picker",
      "id": "column_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "column_2_heading",
      "label": "Heading",
      "default": "Product B"
    },
    {
      "type": "header",
      "content": "Column headings style"
    },
    {
      "type": "color",
      "id": "column_heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "column_heading_size",
      "label": "Size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "image_spacing",
      "label": "Bottom spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Row 1"
    },
    {
      "type": "text",
      "id": "row_1_col_1_text",
      "label": "Column 1 text",
      "default": "Premium quality"
    },
    {
      "type": "text",
      "id": "row_1_col_2_text",
      "label": "Column 2 text",
      "default": "Standard quality"
    },
    {
      "type": "header",
      "content": "Row 2"
    },
    {
      "type": "text",
      "id": "row_2_col_1_text",
      "label": "Column 1 text",
      "default": "Free shipping"
    },
    {
      "type": "text",
      "id": "row_2_col_2_text",
      "label": "Column 2 text",
      "default": "Paid shipping"
    },
    {
      "type": "header",
      "content": "Row 3"
    },
    {
      "type": "text",
      "id": "row_3_col_1_text",
      "label": "Column 1 text",
      "default": "2 year warranty"
    },
    {
      "type": "text",
      "id": "row_3_col_2_text",
      "label": "Column 2 text",
      "default": "1 year warranty"
    },
    {
      "type": "header",
      "content": "Row 4"
    },
    {
      "type": "text",
      "id": "row_4_col_1_text",
      "label": "Column 1 text",
      "default": "24/7 support"
    },
    {
      "type": "text",
      "id": "row_4_col_2_text",
      "label": "Column 2 text",
      "default": "Email support"
    },
    {
      "type": "header",
      "content": "Row 5"
    },
    {
      "type": "text",
      "id": "row_5_col_1_text",
      "label": "Column 1 text",
      "default": "Money back guarantee"
    },
    {
      "type": "text",
      "id": "row_5_col_2_text",
      "label": "Column 2 text",
      "default": "No refunds"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "color",
      "id": "tick_color",
      "label": "Tick color",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "cross_color",
      "label": "Cross color",
      "default": "#D82C0D"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Cell text style"
    },
    {
      "type": "color",
      "id": "cell_text_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "cell_text_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Table style"
    },
    {
      "type": "range",
      "id": "cell_padding",
      "label": "Cell padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "row_border_color",
      "label": "Row border color",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "row_border_width",
      "label": "Row border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Comparison table"
    }
  ]
}
{% endschema %}