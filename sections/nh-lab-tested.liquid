{% comment %}
  Nourish Her - Lab Tested Section
  Transparency and trust messaging
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-lab-text p {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-lab-badge {
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-lab-download {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    margin-top: 32px;
    border-top: 1.5px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    border-bottom: 1.5px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    text-decoration: none;
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }
  #nh-section-{{ section.id }} .nh-lab-download:hover {
    opacity: 0.7;
  }
  #nh-section-{{ section.id }} .nh-lab-download svg {
    color: {{ section.settings.heading_color }};
  }
{% endstyle %}

<section class="nh-section nh-lab-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    <div class="nh-lab-grid" style="{% if section.settings.image_position == 'left' %}direction: rtl;{% endif %}">
      <div class="nh-lab-text" style="{% if section.settings.image_position == 'left' %}direction: ltr;{% endif %}">
        {% if section.settings.paragraph_1 != blank %}
          <p>{{ section.settings.paragraph_1 }}</p>
        {% endif %}
        
        {% if section.settings.paragraph_2 != blank %}
          <p>{{ section.settings.paragraph_2 }}</p>
        {% endif %}
        
        {% if section.settings.paragraph_3 != blank %}
          <p>{{ section.settings.paragraph_3 }}</p>
        {% endif %}
        
        {% if section.blocks.size > 0 %}
          <div class="nh-lab-badges">
            {% for block in section.blocks %}
              {% if block.type == 'badge' %}
                {% assign vis_class = '' %}
                {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
                {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}
                <span class="nh-lab-badge{{ vis_class }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
              {% endif %}
            {% endfor %}
          </div>

          {% for block in section.blocks %}
            {% if block.type == 'image' and block.settings.column == 'left' %}
              {% assign vis_class = '' %}
              {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
              {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}
              <div class="nh-lab-block-image{{ vis_class }}" {{ block.shopify_attributes }} style="margin-top: 24px;">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy' }}
                {% elsif block.settings.image_url != blank %}
                  <img src="{{ block.settings.image_url }}" alt="Lab tested image" width="600" height="400" style="width: 100%; height: auto; border-radius: 20px; object-fit: cover;" />
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}

        {% if section.settings.download_url != blank %}
          <a href="{{ section.settings.download_url }}" class="nh-lab-download" target="_blank">
            <span>{{ section.settings.download_text }}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </a>
        {% endif %}
      </div>
      
      <div class="nh-lab-image" style="{% if section.settings.image_position == 'left' %}direction: ltr;{% endif %}">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 600 | image_tag: alt: section.settings.image.alt, loading: 'lazy', width: section.settings.image.width, height: section.settings.image.height }}
        {% elsif section.settings.image_url != blank %}
          <img src="{{ section.settings.image_url }}" alt="Lab Tested" width="600" height="600" style="width: 100%; height: auto; border-radius: 20px;" />
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-lab-image' }}
        {% endif %}

        {% for block in section.blocks %}
          {% if block.type == 'image' and block.settings.column == 'right' %}
            {% assign vis_class = '' %}
            {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
            {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}
            <div class="nh-lab-block-image{{ vis_class }}" {{ block.shopify_attributes }} style="margin-top: 24px;">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy' }}
              {% elsif block.settings.image_url != blank %}
                <img src="{{ block.settings.image_url }}" alt="Lab tested image" width="600" height="400" style="width: 100%; height: auto; border-radius: 20px; object-fit: cover;" />
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NH - Lab Tested",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#cc0019"
    },
    {
      "type": "header",
      "content": "Image Position"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "right", "label": "Right (default)" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Transparency & Trust"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Third-Party <em>Lab Tested</em></p>"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "We believe you should know exactly what you're putting into your body. That's why every single batch of Nourish Her™ is independently tested by a certified third-party laboratory for purity, potency, and the absence of heavy metals, contaminants, and pathogens."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Our test results are available on request — because transparency isn't a marketing claim, it's a standard we hold ourselves to."
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraph 3",
      "default": "When you choose Nourish Her™, you're choosing a supplement brand that prioritises your health over shortcuts."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_url",
      "label": "Image URL (external)"
    },
    {
      "type": "header",
      "content": "Download Box"
    },
    {
      "type": "text",
      "id": "download_text",
      "label": "Download Text",
      "default": "DOWNLOAD THE LAB TEST RESULTS"
    },
    {
      "type": "url",
      "id": "download_url",
      "label": "PDF Download Link"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge Text",
          "default": "Non-GMO"
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    },
    {
      "type": "image",
      "name": "Image Block",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "right"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Image URL (external)"
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Lab Tested",
      "blocks": {
        "badge_1": { "type": "badge", "settings": { "text": "Non-GMO" } },
        "badge_2": { "type": "badge", "settings": { "text": "Gluten-Free" } },
        "badge_3": { "type": "badge", "settings": { "text": "No Fillers" } },
        "badge_4": { "type": "badge", "settings": { "text": "No Binders" } },
        "badge_5": { "type": "badge", "settings": { "text": "Freeze-Dried" } },
        "badge_6": { "type": "badge", "settings": { "text": "Heavy Metal Tested" } }
      },
      "block_order": ["badge_1", "badge_2", "badge_3", "badge_4", "badge_5", "badge_6"]
    }
  ]
}
{% endschema %}
