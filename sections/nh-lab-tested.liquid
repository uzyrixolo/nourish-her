{% comment %}
  Nourish Her - Lab Tested Section
  Transparency and trust messaging with draggable blocks.
  All block types can be placed in either column and reordered freely.
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-lab-block-text,
  #nh-section-{{ section.id }} .nh-lab-block-text p {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-lab-badge {
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-lab-download {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    margin-top: 32px;
    border-top: 1.5px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    border-bottom: 1.5px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    text-decoration: none;
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }
  #nh-section-{{ section.id }} .nh-lab-download:hover {
    opacity: 0.7;
  }
  #nh-section-{{ section.id }} .nh-lab-download svg {
    color: {{ section.settings.heading_color }};
  }
{% endstyle %}

<section class="nh-section nh-lab-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="nh-divider"></div>

    <div class="nh-lab-grid">

      {% comment %} ========== LEFT COLUMN ========== {% endcomment %}
      <div class="nh-lab-text">
        {% for block in section.blocks %}
          {% if block.settings.column == 'left' %}
            {% assign vis_class = '' %}
            {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
            {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}

            {% case block.type %}

              {% when 'text' %}
                <div class="nh-lab-block-text{{ vis_class }}" {{ block.shopify_attributes }}>
                  {{ block.settings.content }}
                </div>

              {% when 'image' %}
                <div class="nh-lab-block-image{{ vis_class }}" {{ block.shopify_attributes }}>
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy' }}
                  {% elsif block.settings.image_url != blank %}
                    <img src="{{ block.settings.image_url }}" alt="Lab tested image" width="600" height="400" style="width: 100%; height: auto; border-radius: 20px; object-fit: cover;" />
                  {% endif %}
                </div>

              {% when 'badges' %}
                <div class="nh-lab-badges{{ vis_class }}" {{ block.shopify_attributes }}>
                  {% for i in (1..6) %}
                    {% capture badge_key %}badge_{{ i }}{% endcapture %}
                    {% assign badge_text = block.settings[badge_key] %}
                    {% if badge_text != blank %}
                      <span class="nh-lab-badge">{{ badge_text }}</span>
                    {% endif %}
                  {% endfor %}
                </div>

              {% when 'download' %}
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" class="nh-lab-download{{ vis_class }}" {{ block.shopify_attributes }} target="_blank">
                    <span>{{ block.settings.text }}</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                  </a>
                {% endif %}

            {% endcase %}
          {% endif %}
        {% endfor %}
      </div>

      {% comment %} ========== RIGHT COLUMN ========== {% endcomment %}
      <div class="nh-lab-image">
        {% for block in section.blocks %}
          {% if block.settings.column == 'right' %}
            {% assign vis_class = '' %}
            {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
            {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}

            {% case block.type %}

              {% when 'text' %}
                <div class="nh-lab-block-text{{ vis_class }}" {{ block.shopify_attributes }}>
                  {{ block.settings.content }}
                </div>

              {% when 'image' %}
                <div class="nh-lab-block-image{{ vis_class }}" {{ block.shopify_attributes }}>
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy' }}
                  {% elsif block.settings.image_url != blank %}
                    <img src="{{ block.settings.image_url }}" alt="Lab tested image" width="600" height="400" style="width: 100%; height: auto; border-radius: 20px; object-fit: cover;" />
                  {% endif %}
                </div>

              {% when 'badges' %}
                <div class="nh-lab-badges{{ vis_class }}" {{ block.shopify_attributes }}>
                  {% for i in (1..6) %}
                    {% capture badge_key %}badge_{{ i }}{% endcapture %}
                    {% assign badge_text = block.settings[badge_key] %}
                    {% if badge_text != blank %}
                      <span class="nh-lab-badge">{{ badge_text }}</span>
                    {% endif %}
                  {% endfor %}
                </div>

              {% when 'download' %}
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" class="nh-lab-download{{ vis_class }}" {{ block.shopify_attributes }} target="_blank">
                    <span>{{ block.settings.text }}</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                  </a>
                {% endif %}

            {% endcase %}
          {% endif %}
        {% endfor %}
      </div>

    </div>
  </div>
</section>

