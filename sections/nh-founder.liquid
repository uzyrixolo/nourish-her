{% comment %}
  Nourish Her - Founder Story Section
  Doctor's journey narrative with dual columns and draggable content blocks inside them.
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-founder-block-text,
  #nh-section-{{ section.id }} .nh-founder-block-text p {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-founder-quote {
    background: {{ section.settings.quote_bg }};
    color: {{ section.settings.quote_text }};
    border-left-color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-founder-sig {
    color: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section class="nh-section nh-founder-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    <div class="nh-founder-stack">
      {%- comment -%}
        Render blocks grouped by their "row" setting. Each row is its own
        2-column container, so left + right children are paired visually.
        Supports up to 10 rows. Blocks without an explicit row default to 1.
      {%- endcomment -%}
      {%- for row_num in (1..10) -%}
        {%- assign _row_has_content = false -%}
        {%- for block in section.blocks -%}
          {%- assign _r = block.settings.row | default: 1 | plus: 0 -%}
          {%- if _r == row_num -%}
            {%- assign _row_has_content = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if _row_has_content -%}
          <div class="nh-founder-row" data-row="{{ row_num }}">
            <div class="nh-founder-row-col nh-founder-row-left">
              {% for block in section.blocks %}
                {%- assign _r = block.settings.row | default: 1 | plus: 0 -%}
                {% if _r == row_num and block.settings.column == 'left' %}
                  {% assign vis_class = '' %}
                  {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
                  {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}
                  {%- assign _fs_d = block.settings.font_size_desktop | default: 0 | plus: 0 -%}
                  {%- assign _fs_m = block.settings.font_size_mobile | default: 0 | plus: 0 -%}
                  {%- assign _pt_d = block.settings.padding_top_desktop | default: 0 | plus: 0 -%}
                  {%- assign _pb_d = block.settings.padding_bottom_desktop | default: 0 | plus: 0 -%}
                  {%- assign _pt_m = block.settings.padding_top_mobile | default: 0 | plus: 0 -%}
                  {%- assign _pb_m = block.settings.padding_bottom_mobile | default: 0 | plus: 0 -%}
                  {%- assign _text_style = '' -%}
                  {%- if _fs_d > 0 -%}{%- assign _text_style = _text_style | append: '--nh-fs-d:' | append: _fs_d | append: 'px;' -%}{%- endif -%}
                  {%- if _fs_m > 0 -%}{%- assign _text_style = _text_style | append: '--nh-fs-m:' | append: _fs_m | append: 'px;' -%}{%- endif -%}
                  {%- if _pt_d > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pt-d:' | append: _pt_d | append: 'px;' -%}{%- endif -%}
                  {%- if _pb_d > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pb-d:' | append: _pb_d | append: 'px;' -%}{%- endif -%}
                  {%- if _pt_m > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pt-m:' | append: _pt_m | append: 'px;' -%}{%- endif -%}
                  {%- if _pb_m > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pb-m:' | append: _pb_m | append: 'px;' -%}{%- endif -%}
                  {% case block.type %}
                    {% when 'text' %}
                      <div class="nh-founder-block-text{{ vis_class }}" {{ block.shopify_attributes }}{% if _text_style != blank %} style="{{ _text_style }}"{% endif %}>
                        {{ block.settings.content }}
                      </div>
                    {% when 'quote' %}
                      <div class="nh-founder-quote{{ vis_class }}" {{ block.shopify_attributes }}>
                        {{ block.settings.quote }}
                      </div>
                    {% when 'signature' %}
                      <div class="nh-founder-sig{{ vis_class }}" {{ block.shopify_attributes }}>
                        {{ block.settings.signature }}
                      </div>
                    {% when 'image' %}
                      <div class="nh-founder-block-image{{ vis_class }}" {{ block.shopify_attributes }}>
                        {% if block.settings.image != blank %}
                          {{ block.settings.image | image_url: width: 1200 | image_tag: alt: block.settings.image.alt, loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height, widths: '400, 600, 800, 1000, 1200' }}
                        {% elsif block.settings.image_url != blank %}
                          <img src="{{ block.settings.image_url }}" alt="Founder story inline image" width="600" height="600" style="border-radius: 20px; width: 100%; object-fit: cover; box-shadow: 0 8px 32px rgba(0,0,0,0.1);" />
                        {% else %}
                          {{ 'lifestyle-2' | placeholder_svg_tag: 'nh-founder-placeholder' }}
                        {% endif %}
                      </div>
                  {% endcase %}
                {% endif %}
              {% endfor %}
            </div>

            <div class="nh-founder-row-col nh-founder-row-right">
              {% for block in section.blocks %}
                {%- assign _r = block.settings.row | default: 1 | plus: 0 -%}
                {% if _r == row_num and block.settings.column == 'right' %}
                  {% assign vis_class = '' %}
                  {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
                  {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}
                  {%- assign _fs_d = block.settings.font_size_desktop | default: 0 | plus: 0 -%}
                  {%- assign _fs_m = block.settings.font_size_mobile | default: 0 | plus: 0 -%}
                  {%- assign _pt_d = block.settings.padding_top_desktop | default: 0 | plus: 0 -%}
                  {%- assign _pb_d = block.settings.padding_bottom_desktop | default: 0 | plus: 0 -%}
                  {%- assign _pt_m = block.settings.padding_top_mobile | default: 0 | plus: 0 -%}
                  {%- assign _pb_m = block.settings.padding_bottom_mobile | default: 0 | plus: 0 -%}
                  {%- assign _text_style = '' -%}
                  {%- if _fs_d > 0 -%}{%- assign _text_style = _text_style | append: '--nh-fs-d:' | append: _fs_d | append: 'px;' -%}{%- endif -%}
                  {%- if _fs_m > 0 -%}{%- assign _text_style = _text_style | append: '--nh-fs-m:' | append: _fs_m | append: 'px;' -%}{%- endif -%}
                  {%- if _pt_d > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pt-d:' | append: _pt_d | append: 'px;' -%}{%- endif -%}
                  {%- if _pb_d > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pb-d:' | append: _pb_d | append: 'px;' -%}{%- endif -%}
                  {%- if _pt_m > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pt-m:' | append: _pt_m | append: 'px;' -%}{%- endif -%}
                  {%- if _pb_m > 0 -%}{%- assign _text_style = _text_style | append: '--nh-pb-m:' | append: _pb_m | append: 'px;' -%}{%- endif -%}
                  {% case block.type %}
                    {% when 'text' %}
                      <div class="nh-founder-block-text{{ vis_class }}" {{ block.shopify_attributes }}{% if _text_style != blank %} style="{{ _text_style }}"{% endif %}>
                        {{ block.settings.content }}
                      </div>
                    {% when 'quote' %}
                      <div class="nh-founder-quote{{ vis_class }}" {{ block.shopify_attributes }}>
                        {{ block.settings.quote }}
                      </div>
                    {% when 'signature' %}
                      <div class="nh-founder-sig{{ vis_class }}" {{ block.shopify_attributes }}>
                        {{ block.settings.signature }}
                      </div>
                    {% when 'image' %}
                      <div class="nh-founder-block-image{{ vis_class }}" {{ block.shopify_attributes }}>
                        {% if block.settings.image != blank %}
                          {{ block.settings.image | image_url: width: 1200 | image_tag: alt: block.settings.image.alt, loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height, widths: '400, 600, 800, 1000, 1200' }}
                        {% elsif block.settings.image_url != blank %}
                          <img src="{{ block.settings.image_url }}" alt="Founder story inline image" width="600" height="600" style="border-radius: 20px; width: 100%; object-fit: cover; box-shadow: 0 8px 32px rgba(0,0,0,0.1);" />
                        {% else %}
                          {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-founder-placeholder' }}
                        {% endif %}
                      </div>
                  {% endcase %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NH - Founder Story",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#cc0019"
    },
    {
      "type": "header",
      "content": "Quote Colors"
    },
    {
      "type": "color",
      "id": "quote_bg",
      "label": "Quote Background",
      "default": "#fffbd5"
    },
    {
      "type": "color",
      "id": "quote_text",
      "label": "Quote Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>A Doctor's Journey Back to <em>Real Nourishment</em></p>"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text Content",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "range",
          "id": "row",
          "label": "Row (pairs left & right blocks with same row)",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Text",
          "default": "<p>Add paragraph text here.</p>"
        },
        {
          "type": "header",
          "content": "Font Size (px) — 0 = use theme default"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Desktop font size",
          "min": 0,
          "max": 40,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Mobile font size",
          "min": 0,
          "max": 32,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "header",
          "content": "Padding (px) — 0 = none"
        },
        {
          "type": "range",
          "id": "padding_top_desktop",
          "label": "Desktop padding top",
          "min": 0,
          "max": 120,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_bottom_desktop",
          "label": "Desktop padding bottom",
          "min": 0,
          "max": 120,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_top_mobile",
          "label": "Mobile padding top",
          "min": 0,
          "max": 80,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding_bottom_mobile",
          "label": "Mobile padding bottom",
          "min": 0,
          "max": 80,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    },
    {
      "type": "image",
      "name": "Image Block",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "right"
        },
        {
          "type": "range",
          "id": "row",
          "label": "Row (pairs left & right blocks with same row)",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Image URL (external)"
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    },
    {
      "type": "quote",
      "name": "Quote Block",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "range",
          "id": "row",
          "label": "Row (pairs left & right blocks with same row)",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This is a highlighted quote."
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    },
    {
      "type": "signature",
      "name": "Signature",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "range",
          "id": "row",
          "label": "Row (pairs left & right blocks with same row)",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1
        },
        {
          "type": "text",
          "id": "signature",
          "label": "Signature Text",
          "default": "— Dr. [Founder Name], Founder of Nourish Her™"
        },
        {
          "type": "header",
          "content": "Visibility"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Founder Story",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "column": "left",
            "content": "<p>I didn't set out to start a supplement brand. <strong>I was simply trying to feel like myself again.</strong></p><p>As a doctor working long, demanding shifts, I lived in a constant state of exhaustion. My energy was low, my focus was slipping, and no matter how much I slept, I never felt restored.</p>"
          }
        },
        {
          "type": "text",
          "settings": {
            "column": "left",
            "content": "<p>That's when I started looking backwards — not forwards. For generations, women were nourished with whole, nutrient-dense foods that supported energy, resilience, and vitality at the root.</p><p>That's when I decided to create <strong>Nourish Her™</strong> — a clean, beef organ supplement to make it easier to get the essential nutrients my body needed.</p>"
          }
        },
        {
          "type": "quote",
          "settings": {
            "column": "left",
            "quote": "For the first time in a long while, it felt like my body was finally getting what it had been quietly asking for — the nutrients it could actually recognise and use."
          }
        },
        {
          "type": "signature",
          "settings": {
            "column": "left"
          }
        },
        {
          "type": "image",
          "settings": {
            "column": "right"
          }
        },
        {
          "type": "image",
          "settings": {
            "column": "right"
          }
        }
      ]
    }
  ]
}
{% endschema %}
