{% comment %}
  Nourish Her - Founder Story Section
  Doctor's journey narrative with images
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

<section class="nh-section nh-founder-section" id="nh-founder">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    <div class="nh-founder-grid">
      <div class="nh-founder-text">
        {% if section.settings.story != blank %}
          {{ section.settings.story }}
        {% endif %}
        
        {% if section.settings.quote != blank %}
          <div class="nh-founder-quote">{{ section.settings.quote }}</div>
        {% endif %}
        
        {% if section.settings.signature != blank %}
          <div class="nh-founder-sig">{{ section.settings.signature }}</div>
        {% endif %}
      </div>
      
      <div class="nh-founder-images">
        {% if section.settings.image_1 != blank %}
          {{ section.settings.image_1 | image_url: width: 600 | image_tag: alt: section.settings.image_1.alt, loading: 'lazy', width: section.settings.image_1.width, height: section.settings.image_1.height }}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'nh-founder-image-1' }}
        {% endif %}
        
        {% if section.settings.image_2 != blank %}
          {{ section.settings.image_2 | image_url: width: 600 | image_tag: alt: section.settings.image_2.alt, loading: 'lazy', width: section.settings.image_2.width, height: section.settings.image_2.height }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-founder-image-2' }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NH - Founder Story",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>A Doctor's Journey Back to <em>Real Nourishment</em></p>"
    },
    {
      "type": "richtext",
      "id": "story",
      "label": "Story Content",
      "default": "<p>I didn't set out to start a supplement brand. <strong>I was simply trying to feel like myself again.</strong></p><p>As a doctor working long, demanding shifts, I lived in a constant state of exhaustion. My energy was low, my focus was slipping, and no matter how much I slept, I never felt restored.</p><p>That's when I started looking backwards — not forwards. For generations, women were nourished with whole, nutrient-dense foods that supported energy, resilience, and vitality at the root.</p><p>That's when I decided to create <strong>Nourish Her™</strong> — a clean, beef organ supplement to make it easier to get the essential nutrients my body needed.</p>"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "For the first time in a long while, it felt like my body was finally getting what it had been quietly asking for — the nutrients it could actually recognise and use."
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature",
      "default": "— Dr. [Founder Name], Founder of Nourish Her™"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    }
  ],
  "presets": [
    {
      "name": "NH - Founder Story"
    }
  ]
}
{% endschema %}
