{% comment %}
  Nourish Her - Founder Story Section
  Doctor's journey narrative with dual columns and draggable content blocks inside them.
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

<section class="nh-section nh-founder-section" id="nh-founder" style="{% if section.settings.bg_color != blank and section.settings.bg_color != "transparent" %}background: {{ section.settings.bg_color }};{% endif %}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    <div class="nh-founder-grid">
      <div class="nh-founder-column nh-founder-text">
        {% for block in section.blocks %}
          {% if block.settings.column == 'left' %}
            {% case block.type %}
              {% when 'text' %}
                <div class="nh-founder-block-text" {{ block.shopify_attributes }}>
                  {{ block.settings.content }}
                </div>
              {% when 'quote' %}
                <div class="nh-founder-quote" {{ block.shopify_attributes }}>
                  {{ block.settings.quote }}
                </div>
              {% when 'signature' %}
                <div class="nh-founder-sig" {{ block.shopify_attributes }}>
                  {{ block.settings.signature }}
                </div>
              {% when 'image' %}
                <div class="nh-founder-block-image" {{ block.shopify_attributes }} style="margin-bottom: 20px;">
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height }}
                  {% elsif block.settings.image_url != blank %}
                    <img src="{{ block.settings.image_url }}" alt="Founder story inline image" width="600" height="600" style="border-radius: 20px; width: 100%; object-fit: cover; box-shadow: 0 8px 32px rgba(0,0,0,0.1);" />
                  {% else %}
                    {{ 'lifestyle-2' | placeholder_svg_tag: 'nh-founder-placeholder' }}
                  {% endif %}
                </div>
            {% endcase %}
          {% endif %}
        {% endfor %}
      </div>
      
      <div class="nh-founder-column nh-founder-images">
        {% for block in section.blocks %}
          {% if block.settings.column == 'right' %}
            {% case block.type %}
              {% when 'text' %}
                <div class="nh-founder-block-text" {{ block.shopify_attributes }}>
                  {{ block.settings.content }}
                </div>
              {% when 'quote' %}
                <div class="nh-founder-quote" {{ block.shopify_attributes }}>
                  {{ block.settings.quote }}
                </div>
              {% when 'signature' %}
                <div class="nh-founder-sig" {{ block.shopify_attributes }}>
                  {{ block.settings.signature }}
                </div>
              {% when 'image' %}
                <div class="nh-founder-block-image" {{ block.shopify_attributes }} style="margin-bottom: 20px;">
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height }}
                  {% elsif block.settings.image_url != blank %}
                    <img src="{{ block.settings.image_url }}" alt="Founder story inline image" width="600" height="600" style="border-radius: 20px; width: 100%; object-fit: cover; box-shadow: 0 8px 32px rgba(0,0,0,0.1);" />
                  {% else %}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-founder-placeholder' }}
                  {% endif %}
                </div>
            {% endcase %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .nh-founder-block-image img {
    border-radius: 20px;
    width: 100%;
    object-fit: cover;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }
  .nh-founder-column:empty {
    display: none;
  }
</style>

{% schema %}
{
  "name": "NH - Founder Story",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>A Doctor's Journey Back to <em>Real Nourishment</em></p>"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text Content",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Text",
          "default": "<p>Add paragraph text here.</p>"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image Block",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "right"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Image URL (external)"
        }
      ]
    },
    {
      "type": "quote",
      "name": "Quote Block",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This is a highlighted quote."
        }
      ]
    },
    {
      "type": "signature",
      "name": "Signature",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "signature",
          "label": "Signature Text",
          "default": "— Dr. [Founder Name], Founder of Nourish Her™"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Founder Story",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "column": "left",
            "content": "<p>I didn't set out to start a supplement brand. <strong>I was simply trying to feel like myself again.</strong></p><p>As a doctor working long, demanding shifts, I lived in a constant state of exhaustion. My energy was low, my focus was slipping, and no matter how much I slept, I never felt restored.</p>"
          }
        },
        {
          "type": "text",
          "settings": {
            "column": "left",
            "content": "<p>That's when I started looking backwards — not forwards. For generations, women were nourished with whole, nutrient-dense foods that supported energy, resilience, and vitality at the root.</p><p>That's when I decided to create <strong>Nourish Her™</strong> — a clean, beef organ supplement to make it easier to get the essential nutrients my body needed.</p>"
          }
        },
        {
          "type": "quote",
          "settings": {
            "column": "left",
            "quote": "For the first time in a long while, it felt like my body was finally getting what it had been quietly asking for — the nutrients it could actually recognise and use."
          }
        },
        {
          "type": "signature",
          "settings": {
            "column": "left"
          }
        },
        {
          "type": "image",
          "settings": {
            "column": "right"
          }
        },
        {
          "type": "image",
          "settings": {
            "column": "right"
          }
        }
      ]
    }
  ]
}
{% endschema %}
