{% comment %}
  Nourish Her - Hero Section
  Two-column hero with fully draggable blocks.
  All block types can be placed in either column and reordered freely.
  Blocks inherit section-level colors when their own color settings are left at defaults.
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    {% if section.settings.reverse_mobile %}--nh-hero-right-order: 1;{% else %}--nh-hero-right-order: -1;{% endif %}
  }
  #nh-section-{{ section.id }} svg circle {
    fill: {{ section.settings.accent_color }};
  }
{% endstyle %}

{% comment %} ===== BLOCK RENDER SNIPPET (used for both columns) ===== {% endcomment %}
{% capture _nh_block_render %}__NH_BLOCK_PLACEHOLDER__{% endcapture %}

<section class="nh-hero" id="nh-section-{{ section.id }}">
  <div class="nh-hero-grid">

    {% comment %} ========== LEFT COLUMN ========== {% endcomment %}
    <div class="nh-hero-left">
      {% for block in section.blocks %}
        {% if block.settings.column == 'left' %}
          {% assign vis_class = '' %}
          {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
          {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}

          {% case block.type %}

            {% when 'eyebrow' %}
              {% assign _color = block.settings.text_color | default: section.settings.accent_color %}
              {% assign _bg = block.settings.bg_color %}
              <div class="nh-hero-eyebrow{{ vis_class }}" {{ block.shopify_attributes }}
                   style="color: {{ _color }};{% if _bg != blank %}background: {{ _bg }};{% endif %}{% if block.settings.font_size %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != 'left' %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.text }}
              </div>

            {% when 'heading' %}
              {% assign _color = block.settings.heading_color | default: section.settings.heading_color %}
              <h1 class="nh-hero-heading{{ vis_class }}" {{ block.shopify_attributes }}
                  style="color: {{ _color }};{% if block.settings.font_size %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != 'left' %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.text }}
              </h1>

            {% when 'text' %}
              {% assign _color = block.settings.text_color | default: section.settings.text_color %}
              <div class="nh-hero-block-text{{ vis_class }}" {{ block.shopify_attributes }}
                   style="color: {{ _color }};{% if block.settings.font_size %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != 'left' %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.content }}
              </div>

            {% when 'benefit_pills' %}
              {% assign _pill_color = block.settings.pill_text_color | default: section.settings.accent_color %}
              {% assign _pill_border = block.settings.pill_border_color | default: section.settings.accent_color %}
              <div class="nh-hero-block-pills{{ vis_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.pill_alignment != 'flex-start' %}justify-content: {{ block.settings.pill_alignment }};{% endif %}">
                {% for i in (1..5) %}
                  {% capture pill_key %}pill_{{ i }}_text{% endcapture %}
                  {% assign pill_text = block.settings[pill_key] %}
                  {% if pill_text != blank %}
                    <span class="nh-hero-benefit-pill"
                          style="color: {{ _pill_color }}; border-color: {{ _pill_border }};{% if block.settings.pill_bg_color != blank %}background: {{ block.settings.pill_bg_color }};{% endif %}{% if block.settings.pill_font_size %}font-size: {{ block.settings.pill_font_size }}px;{% endif %}">
                      {{ pill_text }}
                    </span>
                  {% endif %}
                {% endfor %}
              </div>

            {% when 'image' %}
              <div class="nh-hero-block-image{{ vis_class }}" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.image.alt, loading: 'lazy' }}
                {% elsif block.settings.image_url != blank %}
                  <img src="{{ block.settings.image_url }}" alt="Hero image" width="800" height="600" loading="lazy" />
                {% endif %}
                {% if block.settings.image_label != blank %}
                  <div class="nh-hero-organ-label">{{ block.settings.image_label }}</div>
                {% endif %}
              </div>

            {% when 'cta' %}
              {% assign _btn_bg = block.settings.btn_bg_color | default: section.settings.accent_color %}
              {% assign _btn_text = block.settings.btn_text_color | default: '#ffffff' %}
              <div class="nh-hero-block-cta{{ vis_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.btn_align != 'left' %}text-align: {{ block.settings.btn_align }};{% endif %}">
                <a href="{{ block.settings.link | default: '#nh-offer' }}"
                   class="nh-btn-primary"
                   style="background: {{ _btn_bg }}; color: {{ _btn_text }} !important;">
                  {{ block.settings.label }}
                </a>
              </div>

            {% when 'trust_badges' %}
              {% assign _badge_color = block.settings.text_color | default: section.settings.text_color %}
              <div class="nh-hero-block-trust{{ vis_class }}" {{ block.shopify_attributes }}
                   style="color: {{ _badge_color }};">
                {% if block.settings.badge_1 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_1 }}
                  </div>
                {% endif %}
                {% if block.settings.badge_2 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_2 }}
                  </div>
                {% endif %}
              </div>

          {% endcase %}
        {% endif %}
      {% endfor %}
    </div>

    {% comment %} ========== RIGHT COLUMN ========== {% endcomment %}
    <div class="nh-hero-right">
      {% for block in section.blocks %}
        {% if block.settings.column == 'right' %}
          {% assign vis_class = '' %}
          {% if block.settings.hide_mobile %}{% assign vis_class = vis_class | append: ' nh-hide-mobile' %}{% endif %}
          {% if block.settings.hide_desktop %}{% assign vis_class = vis_class | append: ' nh-hide-desktop' %}{% endif %}

          {% case block.type %}

            {% when 'eyebrow' %}
              {% assign _color = block.settings.text_color | default: section.settings.accent_color %}
              {% assign _bg = block.settings.bg_color %}
              <div class="nh-hero-eyebrow{{ vis_class }}" {{ block.shopify_attributes }}
                   style="color: {{ _color }};{% if _bg != blank %}background: {{ _bg }};{% endif %}{% if block.settings.font_size %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != 'left' %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.text }}
              </div>

            {% when 'heading' %}
              {% assign _color = block.settings.heading_color | default: section.settings.heading_color %}
              <h1 class="nh-hero-heading{{ vis_class }}" {{ block.shopify_attributes }}
                  style="color: {{ _color }};{% if block.settings.font_size %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != 'left' %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.text }}
              </h1>

            {% when 'text' %}
              {% assign _color = block.settings.text_color | default: section.settings.text_color %}
              <div class="nh-hero-block-text{{ vis_class }}" {{ block.shopify_attributes }}
                   style="color: {{ _color }};{% if block.settings.font_size %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != 'left' %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.content }}
              </div>

            {% when 'benefit_pills' %}
              {% assign _pill_color = block.settings.pill_text_color | default: section.settings.accent_color %}
              {% assign _pill_border = block.settings.pill_border_color | default: section.settings.accent_color %}
              <div class="nh-hero-block-pills{{ vis_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.pill_alignment != 'flex-start' %}justify-content: {{ block.settings.pill_alignment }};{% endif %}">
                {% for i in (1..5) %}
                  {% capture pill_key %}pill_{{ i }}_text{% endcapture %}
                  {% assign pill_text = block.settings[pill_key] %}
                  {% if pill_text != blank %}
                    <span class="nh-hero-benefit-pill"
                          style="color: {{ _pill_color }}; border-color: {{ _pill_border }};{% if block.settings.pill_bg_color != blank %}background: {{ block.settings.pill_bg_color }};{% endif %}{% if block.settings.pill_font_size %}font-size: {{ block.settings.pill_font_size }}px;{% endif %}">
                      {{ pill_text }}
                    </span>
                  {% endif %}
                {% endfor %}
              </div>

            {% when 'image' %}
              <div class="nh-hero-block-image{{ vis_class }}" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.image.alt, loading: 'eager' }}
                {% elsif block.settings.image_url != blank %}
                  <img src="{{ block.settings.image_url }}" alt="Hero image" width="800" height="800" loading="eager" />
                {% endif %}
                {% if block.settings.image_label != blank %}
                  <div class="nh-hero-organ-label">{{ block.settings.image_label }}</div>
                {% endif %}
              </div>

            {% when 'cta' %}
              {% assign _btn_bg = block.settings.btn_bg_color | default: section.settings.accent_color %}
              {% assign _btn_text = block.settings.btn_text_color | default: '#ffffff' %}
              <div class="nh-hero-block-cta{{ vis_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.btn_align != 'left' %}text-align: {{ block.settings.btn_align }};{% endif %}">
                <a href="{{ block.settings.link | default: '#nh-offer' }}"
                   class="nh-btn-primary"
                   style="background: {{ _btn_bg }}; color: {{ _btn_text }} !important;">
                  {{ block.settings.label }}
                </a>
              </div>

            {% when 'trust_badges' %}
              {% assign _badge_color = block.settings.text_color | default: section.settings.text_color %}
              <div class="nh-hero-block-trust{{ vis_class }}" {{ block.shopify_attributes }}
                   style="color: {{ _badge_color }};">
                {% if block.settings.badge_1 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_1 }}
                  </div>
                {% endif %}
                {% if block.settings.badge_2 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_2 }}
                  </div>
                {% endif %}
              </div>

          {% endcase %}
        {% endif %}
      {% endfor %}

      {% comment %} Fallback: show section-level hero_image if no image blocks in right column {% endcomment %}
      {% assign has_right_image = false %}
      {% for block in section.blocks %}
        {% if block.settings.column == 'right' and block.type == 'image' %}
          {% assign has_right_image = true %}
        {% endif %}
      {% endfor %}
      {% unless has_right_image %}
        {% if section.settings.hero_image != blank %}
          <div class="nh-hero-image-wrap">
            {{ section.settings.hero_image | image_url: width: 800 | image_tag: alt: section.settings.hero_image.alt, loading: 'eager' }}
            {% if section.settings.image_label != blank %}
              <div class="nh-hero-organ-label">{{ section.settings.image_label }}</div>
            {% endif %}
          </div>
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-hero-placeholder' }}
        {% endif %}
      {% endunless %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "NH - Hero",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors (inherited by blocks)"
    },
    {
      "type": "paragraph",
      "content": "These colors are used as defaults by all blocks. Override them per-block if needed."
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "linear-gradient(135deg, #fffbd5 0%, #fff 100%)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Eyebrow, Pills, CTA, Badges)",
      "default": "#cc0019"
    },
    {
      "type": "header",
      "content": "Fallback Image"
    },
    {
      "type": "paragraph",
      "content": "Shown in the right column only if no Image block is placed there."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "image_label",
      "label": "Image Label Overlay",
      "default": "6 Whole-Food Beef Organs in Every Serving"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "checkbox",
      "id": "reverse_mobile",
      "label": "Show text above image on mobile",
      "default": false,
      "info": "When enabled, the left column (text) appears before the right column (image) on mobile. Default shows image on top."
    },
    {
      "type": "header",
      "content": "Sticky CTA (used by other sections)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Sticky Nav CTA Text",
      "default": "Shop Now — from £34.99"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow Tag",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Eyebrow Text",
          "default": "Whole-Food Nutrition for Women"
        },
        {
          "type": "header",
          "content": "Style"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "info": "Leave blank to use section Accent Color"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#ffd4e2"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 10,
          "max": 18,
          "step": 1,
          "unit": "px",
          "label": "Font Size",
          "default": 12
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "header",
