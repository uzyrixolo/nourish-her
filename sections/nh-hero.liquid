{% comment %}
  Nourish Her - Hero Section
  Two-column hero with text content and product image
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">



{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    {% if section.settings.reverse_mobile %} --nh-hero-image-order: 1;{% else %} --nh-hero-image-order: -1;{% endif %}
  }
  #nh-section-{{ section.id }} h1 {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-sub, 
  #nh-section-{{ section.id }} .nh-trust-item {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-eyebrow {
    color: {{ section.settings.accent_color }};
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
  }
  #nh-section-{{ section.id }} .nh-btn-primary {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-benefit-pill {
    border-color: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-organ-label {
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.92 }};
  }
  #nh-section-{{ section.id }} svg circle {
    fill: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section class="nh-hero" id="nh-section-{{ section.id }}">
  <div class="nh-hero-text">
    {% if section.settings.eyebrow != blank %}
      <div class="nh-hero-eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h1>{{ section.settings.heading }}</h1>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="nh-hero-sub">{{ section.settings.subheading }}</p>
    {% endif %}
    
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'benefit_pill' %}
          {% if forloop.first %}
            <div class="nh-hero-benefits">
          {% endif %}
          <span class="nh-hero-benefit-pill" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {% if forloop.last %}
            </div>
          {% endif %}
        {% when 'inline_image' %}
          <div class="nh-hero-inline-image" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height }}
            {% elsif block.settings.image_url != blank %}
              <img src="{{ block.settings.image_url }}" alt="Hero inline image" width="600" height="400" style="width: 100%; height: auto; border-radius: 16px; margin: 20px 0;" />
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}
    
    <div class="nh-hero-cta-group">
      <a href="#nh-offer" class="nh-btn-primary" style="color: #fff;">{{ section.settings.cta_button_text }}</a>
    </div>
    
    <div class="nh-hero-trust">
      <div class="nh-trust-item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {{ section.settings.trust_1 }}
      </div>
      <div class="nh-trust-item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {{ section.settings.trust_2 }}
      </div>
    </div>
  </div>
  
  <div class="nh-hero-image-wrap" id="nhHeroImageWrap-{{ section.id }}" style="--img-desktop: {{ section.settings.image_width_desktop }}%; --img-mobile: {{ section.settings.image_width_mobile }}%;">
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 800 | image_tag: alt: section.settings.hero_image.alt, loading: 'eager', width: section.settings.hero_image.width, height: section.settings.hero_image.height }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-hero-placeholder' }}
    {% endif %}
    {% if section.settings.image_label != blank %}
      <div class="nh-hero-organ-label">{{ section.settings.image_label }}</div>
    {% endif %}
  </div>
</section>

<script>
  // Sticky CTA is handled by nh-sticky-cta snippet in nh-offer section
</script>

{% schema %}
{
  "name": "NH - Hero",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "linear-gradient(135deg, #fffbd5 0%, #fff 100%)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#cc0019"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Whole-Food Nutrition for Women"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Why Beef Organ Superfoods Are the Secret to <em>Healthy Hormones & Energy</em></p>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Nourish Her™ is a clean, 100% grass-fed beef organ supplement specifically formulated for women — delivering the ancestral nutrition your body recognises, absorbs, and thrives on."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Start Your Journey"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Sticky Nav CTA Text",
      "default": "Shop Now — from £34.99"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust Badge 1",
      "default": "30-Day Money-Back Guarantee"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust Badge 2",
      "default": "Third-Party Lab Tested"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image Width (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image Width (Mobile)",
      "default": 100
    },
    {
      "type": "text",
      "id": "image_label",
      "label": "Image Label",
      "default": "6 Whole-Food Beef Organs in Every Serving"
    },
    {
      "type": "checkbox",
      "id": "reverse_mobile",
      "label": "Reverse column order on mobile",
      "default": false,
      "info": "When enabled, text appears above the image on mobile. Default shows image on top."
    }
  ],
  "blocks": [
    {
      "type": "benefit_pill",
      "name": "Benefit Pill",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Hormone Support"
        }
      ]
    },
    {
      "type": "inline_image",
      "name": "Inline Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Image URL (external)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Hero",
      "blocks": {
        "pill_1": {
          "type": "benefit_pill",
          "settings": { "text": "Hormone Support" }
        },
        "pill_2": {
          "type": "benefit_pill",
          "settings": { "text": "Sustained Energy" }
        },
        "pill_3": {
          "type": "benefit_pill",
          "settings": { "text": "Skin & Hair Health" }
        },
        "pill_4": {
          "type": "benefit_pill",
          "settings": { "text": "Mental Clarity" }
        }
      },
      "block_order": ["pill_1", "pill_2", "pill_3", "pill_4"]
    }
  ]
}
{% endschema %}
