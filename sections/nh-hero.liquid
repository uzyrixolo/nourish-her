          "default": "<p>Add your text content here.</p>"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        }
      ]
    },
    {
      "type": "benefit_pill",
      "name": "Benefit Pill",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Hormone Support"
        },
        {
          "type": "checkbox",
          "id": "hide_mobile",
          "label": "Hide on mobile",
          "default": false
        }
      ]
    },
    {
      "type": "image",
      "name": "Image Block",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left Column" },
            { "value": "right", "label": "Right Column" }
