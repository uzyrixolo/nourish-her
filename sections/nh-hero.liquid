{% comment %}
  Nourish Her - Hero Section
  Two-column hero with text content and product image
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
  }
  #nh-section-{{ section.id }} h1 {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-sub, 
  #nh-section-{{ section.id }} .nh-trust-item {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-eyebrow {
    color: {{ section.settings.accent_color }};
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
  }
  #nh-section-{{ section.id }} .nh-btn-primary {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-benefit-pill {
    border-color: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-organ-label {
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.92 }};
  }
  #nh-section-{{ section.id }} svg circle {
    fill: {{ section.settings.accent_color }};
  }
  
  /* Mobile ordering based on block position */
  @media (max-width: 768px) {
    {% for block in section.blocks %}
      #nh-section-{{ section.id }} .nh-hero-block[data-block-id="{{ block.id }}"] {
        order: {{ forloop.index }};
      }
    {% endfor %}
  }
{% endstyle %}

<section class="nh-hero" id="nh-section-{{ section.id }}">
  <div class="nh-hero-grid">
    {% comment %} Desktop: Two columns | Mobile: Single column with flex order {% endcomment %}
    
    {% comment %} Render blocks in their actual order - desktop will split into columns via CSS, mobile uses flex order {% endcomment %}
    {% assign in_pill_group = false %}
    {% assign pill_group_column = '' %}
    
    {% for block in section.blocks %}
      {% assign hide_mobile_class = '' %}
      {% if block.settings.hide_mobile %}{% assign hide_mobile_class = ' nh-hide-mobile' %}{% endif %}
      {% assign block_column_class = ' nh-hero-col-' | append: block.settings.column %}
      
      {% if block.type == 'benefit_pill' %}
        {% comment %} Group consecutive pills in the same column {% endcomment %}
        {% if in_pill_group and pill_group_column == block.settings.column %}
          <span class="nh-hero-benefit-pill{{ hide_mobile_class }}" {{ block.shopify_attributes }} data-block-id="{{ block.id }}">{{ block.settings.text }}</span>
        {% else %}
          {% if in_pill_group %}</div>{% endif %}
          {% assign in_pill_group = true %}
          {% assign pill_group_column = block.settings.column %}
          <div class="nh-hero-block-pills{{ block_column_class }}{{ hide_mobile_class }}" {{ block.shopify_attributes }} data-block-id="{{ block.id }}">
            <span class="nh-hero-benefit-pill" style="{% if block.settings.bg_color != blank %}background: {{ block.settings.bg_color }};{% endif %}{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}{% if block.settings.border_color != blank %}border-color: {{ block.settings.border_color }};{% endif %}">{{ block.settings.text }}</span>
        {% endif %}
      {% else %}
        {% if in_pill_group %}</div>{% assign in_pill_group = false %}{% endif %}
        
        {% case block.type %}
          {% when 'text' %}
            <div class="nh-hero-block nh-hero-block-text{{ block_column_class }}{{ hide_mobile_class }}" 
                 {{ block.shopify_attributes }} 
                 data-block-id="{{ block.id }}"
                 style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}{% if block.settings.font_size != blank %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != blank %}text-align: {{ block.settings.text_align }};{% endif %}">
              {{ block.settings.content }}
            </div>
          {% when 'image' %}
            <div class="nh-hero-block nh-hero-block-image{{ block_column_class }}{{ hide_mobile_class }}" 
                 {{ block.shopify_attributes }} 
                 data-block-id="{{ block.id }}">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.image.alt, loading: 'lazy' }}
              {% elsif block.settings.image_url != blank %}
                <img src="{{ block.settings.image_url }}" alt="Hero image" width="800" height="600" />
              {% endif %}
              {% if block.settings.image_label != blank %}
                <div class="nh-hero-organ-label">{{ block.settings.image_label }}</div>
              {% endif %}
            </div>
          {% when 'cta' %}
            <div class="nh-hero-block nh-hero-block-cta{{ block_column_class }}{{ hide_mobile_class }}" 
                 {{ block.shopify_attributes }} 
                 data-block-id="{{ block.id }}"
                 style="{% if block.settings.btn_align != blank %}text-align: {{ block.settings.btn_align }};{% endif %}">
              <a href="{{ block.settings.link | default: '#nh-offer' }}" 
                 class="nh-btn-primary" 
                 style="{% if block.settings.btn_bg_color != blank %}background: {{ block.settings.btn_bg_color }};{% endif %}{% if block.settings.btn_text_color != blank %}color: {{ block.settings.btn_text_color }} !important;{% endif %}">{{ block.settings.label }}</a>
            </div>
          {% when 'trust_badges' %}
            <div class="nh-hero-block nh-hero-block-trust{{ block_column_class }}{{ hide_mobile_class }}" 
                 {{ block.shopify_attributes }} 
                 data-block-id="{{ block.id }}">
              {% if block.settings.badge_1 != blank %}
                <div class="nh-trust-item">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ block.settings.badge_1 }}
                </div>
              {% endif %}
              {% if block.settings.badge_2 != blank %}
                <div class="nh-trust-item">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ block.settings.badge_2 }}
                </div>
              {% endif %}
            </div>
        {% endcase %}
      {% endif %}
    {% endfor %}
    {% if in_pill_group %}</div>{% endif %}
    
    {% comment %} Default product image if no image blocks exist {% endcomment %}
    {% assign has_image_block = false %}
    {% for block in section.blocks %}
      {% if block.type == 'image' %}
        {% assign has_image_block = true %}
      {% endif %}
    {% endfor %}
    
    {% unless has_image_block %}
      <div class="nh-hero-block nh-hero-block-image nh-hero-col-right" id="nhHeroImageWrap-{{ section.id }}">
        {% if section.settings.hero_image != blank %}
          {{ section.settings.hero_image | image_url: width: 800 | image_tag: alt: section.settings.hero_image.alt, loading: 'eager' }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-hero-placeholder' }}
        {% endif %}
        {% if section.settings.image_label != blank %}
          <div class="nh-hero-organ-label">{{ section.settings.image_label }}</div>
        {% endif %}
      </div>
    {% endunless %}
    
    {% comment %} Legacy support: Render eyebrow/heading if no blocks of those types exist {% endcomment %}
    {% assign has_text_block = false %}
    {% for block in section.blocks %}
      {% if block.type == 'text' %}
        {% assign has_text_block = true %}
      {% endif %}
    {% endfor %}
    
    {% unless has_text_block %}
      {% if section.settings.eyebrow != blank %}
        <div class="nh-hero-eyebrow nh-hero-col-left">{{ section.settings.eyebrow }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="nh-hero-col-left">{{ section.settings.heading }}</h1>
      {% endif %}
    {% endunless %}
  </div>
</section>

<script>
  // Sticky CTA is handled by nh-sticky-cta snippet in nh-offer section
</script>

