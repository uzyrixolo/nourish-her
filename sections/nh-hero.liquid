{% comment %}
  Nourish Her - Hero Section
  Two-column hero with text content and product image
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
  }
  #nh-section-{{ section.id }} h1 {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-sub, 
  #nh-section-{{ section.id }} .nh-trust-item {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-eyebrow {
    color: {{ section.settings.accent_color }};
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
  }
  #nh-section-{{ section.id }} .nh-btn-primary {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-benefit-pill {
    border-color: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-hero-organ-label {
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.92 }};
  }
  #nh-section-{{ section.id }} svg circle {
    fill: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section class="nh-hero" id="nh-section-{{ section.id }}">
  <div class="nh-hero-grid">
    {% comment %} Left Column - Text Content {% endcomment %}
    <div class="nh-hero-left">
      {% if section.settings.eyebrow != blank %}
        <div class="nh-hero-eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}
      
      {% comment %} Render left column blocks in order {% endcomment %}
      {% for block in section.blocks %}
        {% if block.settings.column == 'left' %}
          {% assign hide_mobile_class = '' %}
          {% if block.settings.hide_mobile %}{% assign hide_mobile_class = ' nh-hide-mobile' %}{% endif %}
          
          {% case block.type %}
            {% when 'text' %}
              <div class="nh-hero-block-text{{ hide_mobile_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}{% if block.settings.font_size != blank %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != blank %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.content }}
              </div>
            {% when 'benefit_pills' %}
              <div class="nh-hero-block-pills{{ hide_mobile_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.pill_alignment != blank %}justify-content: {{ block.settings.pill_alignment }};{% endif %}">
                {% for i in (1..5) %}
                  {% capture pill_text_key %}pill_{{ i }}_text{% endcapture %}
                  {% assign pill_text = block.settings[pill_text_key] %}
                  {% if pill_text != blank %}
                    <span class="nh-hero-benefit-pill" 
                          style="{% if block.settings.pill_bg_color != blank %}background: {{ block.settings.pill_bg_color }};{% endif %}{% if block.settings.pill_text_color != blank %}color: {{ block.settings.pill_text_color }};{% endif %}{% if block.settings.pill_border_color != blank %}border-color: {{ block.settings.pill_border_color }};{% endif %}{% if block.settings.pill_font_size != blank %}font-size: {{ block.settings.pill_font_size }}px;{% endif %}">{{ pill_text }}</span>
                  {% endif %}
                {% endfor %}
              </div>
            {% when 'image' %}
              <div class="nh-hero-block-image{{ hide_mobile_class }}" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt, loading: 'lazy' }}
                {% elsif block.settings.image_url != blank %}
                  <img src="{{ block.settings.image_url }}" alt="Hero image" width="600" height="400" />
                {% endif %}
              </div>
            {% when 'cta' %}
              <div class="nh-hero-block-cta{{ hide_mobile_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.btn_align != blank %}text-align: {{ block.settings.btn_align }};{% endif %}">
                <a href="{{ block.settings.link | default: '#nh-offer' }}" 
                   class="nh-btn-primary" 
                   style="{% if block.settings.btn_bg_color != blank %}background: {{ block.settings.btn_bg_color }};{% endif %}{% if block.settings.btn_text_color != blank %}color: {{ block.settings.btn_text_color }} !important;{% endif %}">{{ block.settings.label }}</a>
              </div>
            {% when 'trust_badges' %}
              <div class="nh-hero-block-trust{{ hide_mobile_class }}" {{ block.shopify_attributes }}>
                {% if block.settings.badge_1 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_1 }}
                  </div>
                {% endif %}
                {% if block.settings.badge_2 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_2 }}
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        {% endif %}
      {% endfor %}
    </div>
    
    {% comment %} Right Column - Product Image {% endcomment %}
    <div class="nh-hero-right">
      {% for block in section.blocks %}
        {% if block.settings.column == 'right' %}
          {% assign hide_mobile_class = '' %}
          {% if block.settings.hide_mobile %}{% assign hide_mobile_class = ' nh-hide-mobile' %}{% endif %}
          
          {% case block.type %}
            {% when 'image' %}
              <div class="nh-hero-block-image{{ hide_mobile_class }}" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.image.alt, loading: 'eager' }}
                {% elsif block.settings.image_url != blank %}
                  <img src="{{ block.settings.image_url }}" alt="Hero image" width="800" height="800" />
                {% endif %}
                {% if block.settings.image_label != blank %}
                  <div class="nh-hero-organ-label">{{ block.settings.image_label }}</div>
                {% endif %}
              </div>
            {% when 'text' %}
              <div class="nh-hero-block-text{{ hide_mobile_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}{% if block.settings.font_size != blank %}font-size: {{ block.settings.font_size }}px;{% endif %}{% if block.settings.text_align != blank %}text-align: {{ block.settings.text_align }};{% endif %}">
                {{ block.settings.content }}
              </div>
            {% when 'benefit_pills' %}
              <div class="nh-hero-block-pills{{ hide_mobile_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.pill_alignment != blank %}justify-content: {{ block.settings.pill_alignment }};{% endif %}">
                {% for i in (1..5) %}
                  {% capture pill_text_key %}pill_{{ i }}_text{% endcapture %}
                  {% assign pill_text = block.settings[pill_text_key] %}
                  {% if pill_text != blank %}
                    <span class="nh-hero-benefit-pill" 
                          style="{% if block.settings.pill_bg_color != blank %}background: {{ block.settings.pill_bg_color }};{% endif %}{% if block.settings.pill_text_color != blank %}color: {{ block.settings.pill_text_color }};{% endif %}{% if block.settings.pill_border_color != blank %}border-color: {{ block.settings.pill_border_color }};{% endif %}{% if block.settings.pill_font_size != blank %}font-size: {{ block.settings.pill_font_size }}px;{% endif %}">{{ pill_text }}</span>
                  {% endif %}
                {% endfor %}
              </div>
            {% when 'cta' %}
              <div class="nh-hero-block-cta{{ hide_mobile_class }}" {{ block.shopify_attributes }}
                   style="{% if block.settings.btn_align != blank %}text-align: {{ block.settings.btn_align }};{% endif %}">
                <a href="{{ block.settings.link | default: '#nh-offer' }}" 
                   class="nh-btn-primary" 
                   style="{% if block.settings.btn_bg_color != blank %}background: {{ block.settings.btn_bg_color }};{% endif %}{% if block.settings.btn_text_color != blank %}color: {{ block.settings.btn_text_color }} !important;{% endif %}">{{ block.settings.label }}</a>
              </div>
            {% when 'trust_badges' %}
              <div class="nh-hero-block-trust{{ hide_mobile_class }}" {{ block.shopify_attributes }}>
                {% if block.settings.badge_1 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_1 }}
                  </div>
                {% endif %}
                {% if block.settings.badge_2 != blank %}
                  <div class="nh-trust-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8"/><path d="M5 8.5l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ block.settings.badge_2 }}
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        {% endif %}
      {% endfor %}
      
      {% comment %} Default product image if no right column image blocks {% endcomment %}
      {% assign has_right_image = false %}
      {% for block in section.blocks %}
        {% if block.settings.column == 'right' and block.type == 'image' %}
          {% assign has_right_image = true %}
        {% endif %}
      {% endfor %}
      
      {% unless has_right_image %}
        <div class="nh-hero-image-wrap" id="nhHeroImageWrap-{{ section.id }}">
          {% if section.settings.hero_image != blank %}
            {{ section.settings.hero_image | image_url: width: 800 | image_tag: alt: section.settings.hero_image.alt, loading: 'eager' }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'nh-hero-placeholder' }}
          {% endif %}
          {% if section.settings.image_label != blank %}
            <div class="nh-hero-organ-label">{{ section.settings.image_label }}</div>
          {% endif %}
        </div>
      {% endunless %}
    </div>
  </div>
</section>

<script>
  // Sticky CTA is handled by nh-sticky-cta snippet in nh-offer section
</script>

{% schema %}
