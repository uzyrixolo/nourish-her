{% comment %}
  Nourish Her - Sticky Bottom Bar (Standalone Section)
  Renders the sticky bottom CTA snippet. Add this section to any template
  (e.g. the home page) to show the sticky bar. It will appear fixed at
  the bottom of the viewport once the user scrolls past the Hero section.
{% endcomment %}

{% render 'nh-sticky-cta',
  product_title: section.settings.sticky_title,
  cta_text: section.settings.sticky_cta_text,
  cta_link: section.settings.sticky_cta_link,
  enabled: section.settings.sticky_enabled,
  cta_icon: section.settings.sticky_cta_icon,
  cta_icon_size: section.settings.sticky_cta_icon_size,
  trust_1_text: section.settings.sticky_trust_1_text,
  trust_1_icon: section.settings.sticky_trust_1_icon,
  trust_2_text: section.settings.sticky_trust_2_text,
  trust_2_icon: section.settings.sticky_trust_2_icon
%}

{% schema %}
{
  "name": "NH - Sticky Bottom Bar",
  "tag": "section",
  "class": "nh-sticky-bar-wrapper",
  "settings": [
    {
      "type": "paragraph",
      "content": "This bar is fixed at the bottom of the screen. It stays hidden on the Hero section and appears once the user scrolls into the next section."
    },
    {
      "type": "checkbox",
      "id": "sticky_enabled",
      "label": "Show Sticky Bottom Bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "sticky_title",
      "label": "Product Title",
      "default": "Nourish Her™"
    },
    {
      "type": "header",
      "content": "Trust Signals"
    },
    {
      "type": "image_picker",
      "id": "sticky_trust_1_icon",
      "label": "Trust Signal 1 Icon",
      "info": "Optional. Falls back to a shield SVG when blank."
    },
    {
      "type": "text",
      "id": "sticky_trust_1_text",
      "label": "Trust Signal 1 Text",
      "default": "30 Day Money Back Guarantee"
    },
    {
      "type": "image_picker",
      "id": "sticky_trust_2_icon",
      "label": "Trust Signal 2 Icon",
      "info": "Optional. Falls back to a truck SVG when blank."
    },
    {
      "type": "text",
      "id": "sticky_trust_2_text",
      "label": "Trust Signal 2 Text",
      "default": "Free Shipping"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "sticky_cta_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "sticky_cta_link",
      "label": "Button Link (optional)",
      "info": "Leave blank to scroll to the Offer section on the page."
    },
    {
      "type": "image_picker",
      "id": "sticky_cta_icon",
      "label": "Button Icon",
      "info": "Optional icon shown inside the button, next to the text."
    },
    {
      "type": "range",
      "id": "sticky_cta_icon_size",
      "label": "Button Icon Size",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "NH - Sticky Bottom Bar"
    }
  ]
}
{% endschema %}
