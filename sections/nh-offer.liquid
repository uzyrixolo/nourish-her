{% comment %}
  Nourish Her - Offer/Buy Section
  Product gallery with pricing options
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title,
  #nh-section-{{ section.id }} .nh-offer-content h2 {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-tagline,
  #nh-section-{{ section.id }} .nh-money-back {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-pricing-card {
    background: {{ section.settings.card_bg }};
    border-color: {{ section.settings.card_border }};
    color: {{ section.settings.card_text }};
  }
  #nh-section-{{ section.id }} .nh-pricing-card.nh-selected {
    border-color: {{ section.settings.accent_color }};
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.05 }};
  }
  #nh-section-{{ section.id }} .nh-pricing-badge {
    background: {{ section.settings.accent_color }};
    color: #fff;
  }
  #nh-section-{{ section.id }} .nh-btn-primary {
    background: {{ section.settings.accent_color }};
    color: #fff;
    margin-top:25px;
  }
  #nh-section-{{ section.id }} .nh-offer-include-item::before {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-offer-gallery-dot.active {
    background: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section class="nh-section nh-offer-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    <div class="nh-offer-grid">
      <div class="nh-offer-image">
        {%- assign _gallery_product = all_products[section.settings.featured_product] -%}
        {%- assign _use_product_imgs = section.settings.use_product_images -%}
        {%- if _use_product_imgs == nil -%}{%- assign _use_product_imgs = true -%}{%- endif -%}
        {%- assign _product_has_images = false -%}
        {%- if _gallery_product != blank and _gallery_product.images.size > 0 -%}
          {%- assign _product_has_images = true -%}
        {%- endif -%}

        <div class="nh-offer-gallery" id="nhOfferGallery-{{ section.id }}">
          <div class="nh-offer-gallery-track" id="nhOfferGalleryTrack-{{ section.id }}">
            {% if _use_product_imgs and _product_has_images %}
              {%- comment -%} Pull real product images from the attached product {%- endcomment -%}
              {% for image in _gallery_product.images %}
                <div class="nh-offer-gallery-slide">
                  {{ image | image_url: width: 2400 | image_tag: alt: image.alt | default: _gallery_product.title, loading: 'lazy', width: image.width, height: image.height, widths: '400, 600, 800, 1000, 1200, 1600, 2000, 2400', sizes: '(min-width: 992px) 50vw, 100vw' }}
                </div>
              {% endfor %}
            {% else %}
              {%- comment -%} Fallback: render merchant-curated gallery_image blocks {%- endcomment -%}
              {% for block in section.blocks %}
                {% if block.type == 'gallery_image' %}
                  <div class="nh-offer-gallery-slide" {{ block.shopify_attributes }}>
                    {% if block.settings.image != blank %}
                      {{ block.settings.image | image_url: width: 2000 | image_tag: alt: block.settings.image.alt, loading: 'lazy', width: block.settings.image.width, height: block.settings.image.height, widths: '400, 600, 800, 1000, 1200, 1600, 2000', sizes: '(min-width: 992px) 50vw, 100vw' }}
                    {% elsif block.settings.image_url != blank %}
                      <img src="{{ block.settings.image_url }}" alt="Product image {{ forloop.index }}" width="600" height="600" style="width: 100%; height: 100%; object-fit: cover; border-radius: 20px;" />
                    {% else %}
                      {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'nh-gallery-slide' }}
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
        </div>
        <div class="nh-offer-gallery-nav">
          <button class="nh-offer-gallery-arrow nh-prev" onclick="nhGalleryPrev_{{ section.id | replace: '-', '_' }}()" aria-label="Previous">&#8249;</button>
          <div class="nh-offer-gallery-dots" id="nhOfferGalleryDots-{{ section.id }}">
            {% if _use_product_imgs and _product_has_images %}
              {% for image in _gallery_product.images %}
                <button class="nh-offer-gallery-dot{% if forloop.first %} active{% endif %}" onclick="nhGalleryGoTo_{{ section.id | replace: '-', '_' }}({{ forloop.index0 }})"></button>
              {% endfor %}
            {% else %}
              {% assign gallery_count = 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'gallery_image' %}
                  <button class="nh-offer-gallery-dot{% if forloop.first %} active{% endif %}" onclick="nhGalleryGoTo_{{ section.id | replace: '-', '_' }}({{ gallery_count }})"></button>
                  {% assign gallery_count = gallery_count | plus: 1 %}
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
          <button class="nh-offer-gallery-arrow nh-next" onclick="nhGalleryNext_{{ section.id | replace: '-', '_' }}()" aria-label="Next">&#8250;</button>
        </div>
      </div>
      
      <div class="nh-offer-content">
        <h2>{{ section.settings.product_title }}</h2>
        <p class="nh-tagline">{{ section.settings.product_tagline }}</p>
        
        <div class="nh-pricing-options">
          {% assign product = all_products[section.settings.featured_product] %}
          {% if product != blank %}
            {% form 'product', product, id: 'nhOfferForm', class: 'nh-offer-form' %}
              <input type="hidden" name="id" id="nhOfferVariantId" value="{{ product.selected_or_first_available_variant.id }}">
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'pricing_option' %}
                    <div class="nh-pricing-card{% if block.settings.selected %} nh-selected{% endif %}" 
                         data-plan-id="{{ block.settings.plan_id | escape }}"
                         data-price="{{ block.settings.price | escape }}"
                         data-price-display="{{ block.settings.price_display | escape }}"
                         onclick="nhSelectPlan_{{ section.id | replace: '-', '_' }}(this)"
                         style="margin-bottom: 20px;" {{ block.shopify_attributes }}>
                      <div class="nh-pricing-card-header">
                        <div class="nh-pricing-card-label">
                          {{ block.settings.label }}
                          {% if block.settings.badge != blank %}
                            <span class="nh-pricing-badge">{{ block.settings.badge }}</span>
                          {% endif %}
                        </div>
                        <div class="nh-pricing-card-price">{{ block.settings.price_display }}</div>
                      </div>
                      <div class="nh-pricing-card-sub">{{ block.settings.subtext }}</div>
                    </div>
                  {% when '@app' %}
                    <div class="nh-offer-app-block" {{ block.shopify_attributes }}>
                      {% render block %}
                    </div>
                {% endcase %}
              {% endfor %}
              
              <button type="submit" class="nh-btn-primary nh-offer-cta" id="nhOfferCta">
                Add to Cart — {{ product.selected_or_first_available_variant.price | money }}
              </button>
            {% endform %}
          {% else %}
            <!-- Placeholder if no product is selected -->
            <div class="nh-pricing-card nh-selected" style="margin-bottom: 20px;">
              <div class="nh-pricing-card-header">
                <div class="nh-pricing-card-label">One-Time Purchase</div>
                <div class="nh-pricing-card-price">{{ section.settings.fallback_price }}</div>
              </div>
              <div class="nh-pricing-card-sub">Select a product in theme settings to activate purchasing.</div>
            </div>
            <button class="nh-btn-primary nh-offer-cta">Add to Cart</button>
          {% endif %}
        </div>
        
        <div class="nh-offer-includes" style="margin-top: 24px;">
          {% for block in section.blocks %}
            {% if block.type == 'include_item' %}
              <div class="nh-offer-include-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
            {% endif %}
          {% endfor %}
        </div>
        
        <p class="nh-money-back">🛡️ <strong>{{ section.settings.guarantee_title }}.</strong> {{ section.settings.guarantee_text }}</p>
      </div>
    </div>
  </div>
</section>

{% comment %} Sticky Bottom Bar is now a standalone section: sections/nh-sticky-bar.liquid {% endcomment %}

<script>
  // NH Offer Section: dynamic CTA price + direct-to-checkout
  // Works with the Kaching Subscriptions app widget DOM
  (function() {
    var sectionId = "{{ section.id | replace: '-', '_' }}";
    var sectionRootSelector = '#nh-section-{{ section.id }}';

    function getSectionRoot() { return document.querySelector(sectionRootSelector); }

    function getCta() {
      var root = getSectionRoot();
      return root ? root.querySelector('#nhOfferCta') : null;
    }

    // ---- Kaching widget readers (based on real DOM: kaching-subscriptions__card-wrapper.selected) ----
    function getSelectedKachingCard() {
      var root = getSectionRoot();
      if (!root) return null;
      return root.querySelector('.kaching-subscriptions__card-wrapper.selected');
    }

    function getPriceFromKachingCard(card) {
      if (!card) return null;
      // Subscription plan price
      var sub = card.querySelector('.kaching-subscriptions__selling-plan-price');
      if (sub && sub.textContent.trim()) return sub.textContent.trim();
      // One-time purchase price
      var ot = card.querySelector('.kaching-subscriptions__card-price');
      if (ot && ot.textContent.trim()) return ot.textContent.trim();
      return null;
    }

    function isOneTimeSelected() {
      var card = getSelectedKachingCard();
      return !!(card && card.classList.contains('one-time-purchase'));
    }

    // ---- Legacy custom pricing cards (if merchant still uses them) ----
    function getCustomCards() {
      var root = getSectionRoot();
      if (!root) return [];
      return root.querySelectorAll('.nh-pricing-card');
    }
    function getSelectedCustomCard() {
      var cards = getCustomCards();
      for (var i = 0; i < cards.length; i++) {
        if (cards[i].classList.contains('nh-selected')) return cards[i];
      }
      return null;
    }

    // ---- CTA updater: Kaching first, fallback to custom cards ----
    function updateCta() {
      var cta = getCta();
      if (!cta) return;

      var newText = null;

      // 1. Prefer Kaching selection
      var kachingCard = getSelectedKachingCard();
      if (kachingCard) {
        var price = getPriceFromKachingCard(kachingCard);
        if (price) newText = 'Add to Cart — ' + price;
      }

      // 2. Fallback to custom pricing cards
      if (!newText) {
        var customCard = getSelectedCustomCard();
        if (customCard) {
          var cd = customCard.getAttribute('data-price-display');
          if (cd) newText = 'Add to Cart — ' + cd;
        }
      }

      // Guard: only write if text actually changes.
      // Prevents feedback loops with any MutationObserver watching this subtree.
      if (newText && cta.textContent !== newText) {
        cta.textContent = newText;
      }
    }

    // Called by onclick on custom pricing cards (if any)
    window["nhSelectPlan_" + sectionId] = function(cardElement) {
      var cards = getCustomCards();
      for (var i = 0; i < cards.length; i++) cards[i].classList.remove('nh-selected');
      cardElement.classList.add('nh-selected');
      updateCta();
    };

    // ---- Form intercept: AJAX add-to-cart + direct checkout ----
    // Bound in CAPTURE phase with stopImmediatePropagation so it runs BEFORE
    // any Kaching or theme handler and owns the post-add navigation.
    // Read direct_checkout directly from Liquid settings so it's guaranteed present.
    var DIRECT_CHECKOUT = {{ settings.direct_checkout | default: false | json }};
    var CART_ADD_URL = '{{ routes.cart_add_url }}';
    var CART_URL = '{{ routes.cart_url }}';
    var CHECKOUT_URL = '/checkout';

    function performAddToCart(form) {
      console.log('[NH Offer] performAddToCart fired. direct_checkout =', DIRECT_CHECKOUT);
      var cta = getCta();
      var originalCtaText = cta ? cta.textContent : '';
      if (cta) {
        cta.disabled = true;
        cta.textContent = 'Adding…';
      }

      // FormData snapshot taken AFTER Kaching (if any) has injected
      // its hidden selling_plan input.
      var formData = new FormData(form);

      var sellingPlanInput = form.querySelector('input[name="selling_plan"]');
      if (sellingPlanInput && sellingPlanInput.value) {
        formData.set('selling_plan', sellingPlanInput.value);
      } else if (isOneTimeSelected()) {
        formData.delete('selling_plan');
      }

      fetch(CART_ADD_URL, {
        method: 'POST',
        headers: { 'Accept': 'application/javascript', 'X-Requested-With': 'XMLHttpRequest' },
        body: formData
      })
      .then(function(res) {
        return res.json().then(function(data) { return { ok: res.ok, data: data }; });
      })
      .then(function(payload) {
        console.log('[NH Offer] Add-to-cart response ok=', payload.ok, payload.data);
        if (!payload.ok) {
          var msg = (payload.data && (payload.data.description || payload.data.message)) || 'Unable to add to cart.';
          if (cta) { cta.disabled = false; cta.textContent = originalCtaText || 'Add to Cart'; }
          alert(msg);
          return;
        }
        var target = DIRECT_CHECKOUT ? CHECKOUT_URL : CART_URL;
        console.log('[NH Offer] Redirecting to:', target);
        window.location.href = target;
      })
      .catch(function(err) {
        console.error('[NH Offer] Add-to-cart failed:', err);
        if (cta) { cta.disabled = false; cta.textContent = originalCtaText || 'Add to Cart'; }
        alert('Network error. Please try again.');
      });
    }

    function interceptForm() {
      var root = getSectionRoot();
      if (!root) return;
      var form = root.querySelector('#nhOfferForm');
      if (!form || form.dataset.nhBound === '1') return;
      form.dataset.nhBound = '1';

      // Primary: form submit in capture phase
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        e.stopImmediatePropagation();
        performAddToCart(form);
      }, true);

      // Safety net: CTA button click in capture phase.
      // Handles the case where another script (e.g. Kaching) preventDefaults
      // the click and prevents the form from ever dispatching its submit event.
      var cta = form.querySelector('#nhOfferCta');
      if (cta) {
        cta.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopImmediatePropagation();
          performAddToCart(form);
        }, true);
      }
    }

    // ---- Observe Kaching card selection changes ----
    // Scoped to the Kaching app-block ONLY (never the whole section) to avoid
    // a feedback loop where updating the CTA text would fire this observer.
    var observer = new MutationObserver(function() { updateCta(); });

    function startObservingKaching() {
      var root = getSectionRoot();
      if (!root) return false;
      var kachingRoot = root.querySelector('.nh-offer-app-block, .kaching-subscriptions__cards-wrapper');
      if (!kachingRoot) return false;
      observer.observe(kachingRoot, {
        subtree: true,
        attributes: true,
        attributeFilter: ['class']
      });
      return true;
    }

    function init() {
      updateCta();
      interceptForm();

      // Try to attach the observer now; if Kaching hasn't rendered yet, retry briefly.
      if (!startObservingKaching()) {
        var tries = 0;
        var retry = setInterval(function() {
          tries++;
          if (startObservingKaching() || tries > 20) clearInterval(retry);
        }, 250);
      }

      // Also listen for clicks inside the Kaching widget (their cards are role="button" divs)
      var root = getSectionRoot();
      if (root) {
        root.addEventListener('click', function(e) {
          if (e.target.closest('.kaching-subscriptions__card-wrapper')) {
            // Defer to let Kaching update .selected class first
            setTimeout(updateCta, 50);
            setTimeout(updateCta, 250);
          }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();

  (function() {
    // Offer image gallery - scoped
    let nhGalleryIndex = 0;
    const sectionId = "{{ section.id | replace: '-', '_' }}";
    const nhGalleryTrack = document.getElementById('nhOfferGalleryTrack-{{ section.id }}');
    const nhGalleryDots = document.querySelectorAll('#nhOfferGalleryDots-{{ section.id }} .nh-offer-gallery-dot');
    const nhGallerySlides = document.querySelectorAll('#nhOfferGalleryTrack-{{ section.id }} .nh-offer-gallery-slide');

    window["nhGalleryGoTo_" + sectionId] = function(index) {
      nhGalleryIndex = index;
      if (nhGalleryTrack) {
        nhGalleryTrack.style.transform = `translateX(-${nhGalleryIndex * 100}%)`;
      }
      nhGalleryDots.forEach((d, i) => d.classList.toggle('active', i === nhGalleryIndex));
    };
    
    window["nhGalleryNext_" + sectionId] = function() {
      if(nhGallerySlides.length === 0) return;
      window["nhGalleryGoTo_" + sectionId]((nhGalleryIndex + 1) % nhGallerySlides.length);
    };
    
    window["nhGalleryPrev_" + sectionId] = function() {
      if(nhGallerySlides.length === 0) return;
      window["nhGalleryGoTo_" + sectionId]((nhGalleryIndex - 1 + nhGallerySlides.length) % nhGallerySlides.length);
    };

    // Touch swipe for gallery
    const el = document.getElementById('nhOfferGallery-{{ section.id }}');
    if (el) {
      let startX = 0;
      el.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, {passive:true});
      el.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) dx < 0 ? window["nhGalleryNext_" + sectionId]() : window["nhGalleryPrev_" + sectionId]();
      }, {passive:true});
    }
  })();

  // ---------------------------------------------------------------
  // Kaching Subscriptions widget — subtitle patcher
  // Replaces the selling-plan subtitle text inside the widget:
  //   - One-time purchase card: inject a subtitle (Kaching omits by default)
  //   - Subscribe & save card: overwrite the default "Delivery: every ..." line
  // Uses a MutationObserver so it survives Kaching's re-renders.
  // ---------------------------------------------------------------
  (function() {
    var ONETIME_SUBTITLE = {{ section.settings.kaching_onetime_subtitle | default: '' | json }};
    var SUB_SUBTITLE    = {{ section.settings.kaching_subscription_subtitle | default: '' | json }};
    if (!ONETIME_SUBTITLE && !SUB_SUBTITLE) return;

    var root = document.getElementById('nh-offer') || document;

    function buildSubtitleNode(text) {
      var info = document.createElement('div');
      info.className = 'kaching-subscriptions__selling-plan-info nh-kaching-injected';
      info.setAttribute('role', 'button');
      info.setAttribute('tabindex', '0');
      info.innerHTML =
        '<div class="kaching-subscriptions__selling-plan-title-and-label-wrapper">' +
          '<div class="kaching-subscriptions__selling-plan-title-wrapper">' +
            '<span class="kaching-subscriptions__selling-plan-title onetime" data-testid="selling-plan-display"></span>' +
          '</div>' +
        '</div>';
      info.querySelector('.kaching-subscriptions__selling-plan-title').textContent = text;
      return info;
    }

    function patch() {
      var wrappers = root.querySelectorAll('.kaching-subscriptions__card-wrapper');
      wrappers.forEach(function(card) {
        var isOneTime = card.classList.contains('one-time-purchase');

        if (isOneTime) {
          if (!ONETIME_SUBTITLE) return;
          // Inject subtitle once per card. If already present, just sync text.
          var existing = card.querySelector(':scope > .nh-kaching-injected .kaching-subscriptions__selling-plan-title');
          if (existing) {
            if (existing.textContent !== ONETIME_SUBTITLE) existing.textContent = ONETIME_SUBTITLE;
          } else {
            card.appendChild(buildSubtitleNode(ONETIME_SUBTITLE));
          }
        } else {
          if (!SUB_SUBTITLE) return;
          // Overwrite the Kaching-rendered selling-plan title text.
          var title = card.querySelector('.kaching-subscriptions__selling-plan-title[data-testid="selling-plan-display"]');
          if (title && title.textContent !== SUB_SUBTITLE) {
            title.textContent = SUB_SUBTITLE;
          }
        }
      });
    }

    // Initial attempt + retries for late-loading widget.
    patch();
    var tries = 0;
    var retry = setInterval(function() {
      patch();
      if (++tries > 20) clearInterval(retry);
    }, 250);

    // Long-term resilience: re-patch on any DOM change inside the offer section.
    var mo = new MutationObserver(function() { patch(); });
    mo.observe(root, { childList: true, subtree: true, characterData: true });
  })();
</script>

{% schema %}
{
  "name": "NH - Offer Section",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#cc0019"
    },
    {
      "type": "header",
      "content": "Card Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card Border",
      "default": "#eeeeee"
    },
    {
      "type": "color",
      "id": "card_text",
      "label": "Card Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Get Started Today"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Choose Your <em>Nourishment Plan</em></p>"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title",
      "default": "Nourish Her™"
    },
    {
      "type": "text",
      "id": "product_tagline",
      "label": "Product Tagline",
      "default": "100% Grass-Fed Beef Organs — Whole-Food Nutrition for Women"
    },
