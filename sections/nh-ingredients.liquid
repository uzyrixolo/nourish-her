{% comment %}
  Nourish Her - Ingredients Section
  Six organ ingredient cards on red background
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #nh-section-{{ section.id }} .nh-ingredient-card .nh-organ-emoji {
    width: var(--nh-ing-img-size, {{ section.settings.image_size | default: 56 }}px);
    height: var(--nh-ing-img-size, {{ section.settings.image_size | default: 56 }}px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  #nh-section-{{ section.id }} .nh-ingredient-custom-img {
    width: var(--nh-ing-img-size, {{ section.settings.image_size | default: 56 }}px);
    height: var(--nh-ing-img-size, {{ section.settings.image_size | default: 56 }}px);
    object-fit: contain;
  }
  #nh-section-{{ section.id }} .nh-ingredient-emoji-text {
    font-size: calc(var(--nh-ing-img-size, {{ section.settings.image_size | default: 56 }}px) * 0.9);
    line-height: 1;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
    #nh-section-{{ section.id }} .nh-ingredient-card .nh-organ-emoji,
    #nh-section-{{ section.id }} .nh-ingredient-custom-img {
      width: var(--nh-ing-img-size-m, var(--nh-ing-img-size, {{ section.settings.image_size_mobile | default: section.settings.image_size | default: 48 }}px));
      height: var(--nh-ing-img-size-m, var(--nh-ing-img-size, {{ section.settings.image_size_mobile | default: section.settings.image_size | default: 48 }}px));
    }
    #nh-section-{{ section.id }} .nh-ingredient-emoji-text {
      font-size: calc(var(--nh-ing-img-size-m, var(--nh-ing-img-size, {{ section.settings.image_size_mobile | default: section.settings.image_size | default: 48 }}px)) * 0.9);
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
    opacity: 1;
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
    opacity: 1;
  }
  #nh-section-{{ section.id }} .nh-section-body {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-card {
    background: {{ section.settings.card_bg }};
    border-color: {{ section.settings.card_border }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-name {
    color: {{ section.settings.card_text_title }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-stat {
    background: {{ section.settings.card_accent }};
    color: {{ section.settings.card_accent_text }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-card p {
    color: {{ section.settings.card_text_body }};
  }
{% endstyle %}

<section class="nh-section nh-ingredients-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    {% if section.settings.description != blank %}
      <p class="nh-section-body">{{ section.settings.description }}</p>
    {% endif %}
    
    {% if section.blocks.size > 0 %}
      <div class="nh-ingredients-grid">
        {% for block in section.blocks %}
          {%- assign vis_class = '' -%}
          {%- if block.settings.hide_mobile -%}{%- assign vis_class = vis_class | append: ' nh-hide-mobile' -%}{%- endif -%}
          {%- if block.settings.hide_desktop -%}{%- assign vis_class = vis_class | append: ' nh-hide-desktop' -%}{%- endif -%}

          {% case block.type %}

            {% when 'heading_image' %}
              {% if block.settings.image != blank %}
                {%- assign _hd_img_d = block.settings.image_width | default: 320 -%}
                {%- assign _hd_img_m = block.settings.image_width_mobile | default: _hd_img_d -%}
                <div class="nh-ingredients-heading-image{{ vis_class }}" {{ block.shopify_attributes }}>
                  <div class="nh-ingredients-heading-image-inner"
                       style="width: {{ _hd_img_d }}px; --hd-w-m: {{ _hd_img_m }}px;">
                    {{ block.settings.image | image_url: width: 1200 | image_tag:
                        alt: block.settings.image.alt | default: 'Ingredients image',
                        loading: 'lazy',
                        class: 'nh-ingredients-heading-image-img'
                    }}
                  </div>
                </div>
              {% endif %}

            {% when 'ingredient' %}
              {%- assign _block_img_size = block.settings.image_size -%}
              {%- if _block_img_size == 0 or _block_img_size == blank -%}
                {%- assign _block_img_size = section.settings.image_size | default: 56 -%}
              {%- endif -%}
              {%- assign _block_img_size_mobile = block.settings.image_size_mobile -%}
              {%- if _block_img_size_mobile == 0 or _block_img_size_mobile == blank -%}
                {%- assign _block_img_size_mobile = section.settings.image_size_mobile | default: _block_img_size -%}
              {%- endif -%}
              {%- assign _img_src_w = _block_img_size | times: 2 -%}
              <div class="nh-ingredient-card{{ vis_class }}" {{ block.shopify_attributes }} style="{% if block.settings.card_bg != blank %}background: {{ block.settings.card_bg }};{% endif %}{% if block.settings.card_border != blank %}border-color: {{ block.settings.card_border }};{% endif %} --nh-ing-img-size: {{ _block_img_size }}px; --nh-ing-img-size-m: {{ _block_img_size_mobile }}px;">
                <div class="nh-ingredient-name">
                  <span class="nh-organ-emoji">
                    {% if block.settings.custom_image != blank %}
                      {{ block.settings.custom_image | image_url: width: _img_src_w | image_tag: alt: block.settings.name, loading: 'lazy', class: 'nh-ingredient-custom-img' }}
                    {% else %}
                      <span class="nh-ingredient-emoji-text">{{ block.settings.emoji }}</span>
                    {% endif %}
                  </span>
                  {{ block.settings.name }}
                </div>
                <div class="nh-ingredient-stat">{{ block.settings.stat }}</div>
                <p>{{ block.settings.description }}</p>
              </div>

          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
