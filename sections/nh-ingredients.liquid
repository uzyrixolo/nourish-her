    },
    {
      "type": "color",
      "id": "card_text_title",
      "label": "Card Title Color",
      "default": "#fffbd5"
    },
    {
      "type": "color",
      "id": "card_text_body",
      "label": "Card Body Color",
      "default": "#fffbd5"
    },
    {
      "type": "color",
      "id": "card_accent",
      "label": "Card Badge Background",
      "default": "#fffbd5"
    },
    {
      "type": "color",
      "id": "card_accent_text",
