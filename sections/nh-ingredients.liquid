    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#cc0019"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#fffbd5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#fffbd5"
    },
    {
      "type": "color",
      "id": "accent_color",
