{% comment %}
  Nourish Her - Ingredients Section
  Six organ ingredient cards on red background
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #nh-section-{{ section.id }} .nh-ingredient-custom-img {
    width: {{ section.settings.image_size | default: 56 }}px;
    height: {{ section.settings.image_size | default: 56 }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
    opacity: 1;
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
    opacity: 1;
  }
  #nh-section-{{ section.id }} .nh-section-body {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-card {
    background: {{ section.settings.card_bg }};
    border-color: {{ section.settings.card_border }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-name {
    color: {{ section.settings.card_text_title }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-stat {
    background: {{ section.settings.card_accent }};
    color: {{ section.settings.card_accent_text }};
  }
  #nh-section-{{ section.id }} .nh-ingredient-card p {
    color: {{ section.settings.card_text_body }};
  }
{% endstyle %}

<section class="nh-section nh-ingredients-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    {% if section.settings.description != blank %}
      <p class="nh-section-body">{{ section.settings.description }}</p>
    {% endif %}
    
    {% if section.blocks.size > 0 %}
      <div class="nh-ingredients-grid">
        {% for block in section.blocks %}
          <div class="nh-ingredient-card" {{ block.shopify_attributes }} style="{% if block.settings.card_bg != blank %}background: {{ block.settings.card_bg }};{% endif %}{% if block.settings.card_border != blank %}border-color: {{ block.settings.card_border }};{% endif %}">
            <div class="nh-ingredient-name">
              <span class="nh-organ-emoji">
                {% if block.settings.custom_image != blank %}
                  {%- assign _img_w = section.settings.image_size | default: 56 | times: 2 -%}
                  {{ block.settings.custom_image | image_url: width: _img_w | image_tag: alt: block.settings.name, loading: 'lazy', class: 'nh-ingredient-custom-img' }}
                {% else %}
                  {{ block.settings.emoji }}
                {% endif %}
              </span>
              {{ block.settings.name }}
            </div>
            <div class="nh-ingredient-stat">{{ block.settings.stat }}</div>
            <p>{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

