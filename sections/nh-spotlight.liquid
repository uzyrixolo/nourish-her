        { "type": "color", "id": "pill_text", "label": "Pill Text", "default": "#1a1a1a" },
        { "type": "color", "id": "pill_border", "label": "Pill Border", "default": "#e5e5e5" },
        { "type": "color", "id": "check_color", "label": "Check Badge", "default": "#4ca96b" },
