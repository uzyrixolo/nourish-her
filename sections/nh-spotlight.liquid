      "label": "Quote Text",
      "default": "I've taken women's vitamins for years and felt no big benefit. I'm now finally noticing steadier energy and more balance after just a few weeks on this."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Author (optional)"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Feature Pill",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Clinically Backed"
        },
        {
          "type": "color",
          "id": "check_color",
          "label": "Check Badge Color",
          "default": "#4ca96b"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Spotlight",
      "blocks": {
        "pill_1": {
          "type": "pill",
          "settings": {
            "text": "Clinically Backed"
          }
        },
        "pill_2": {
          "type": "pill",
          "settings": {
            "text": "All Day Energy"
          }
        }
      },
      "block_order": ["pill_1", "pill_2"]
    }
  ]
}
{% endschema %}
