{% comment %}
  Nourish Her - Spotlight Section
  Fully block-based two-column layout.
  Desktop: two independent flex columns (left / right) — each block picks its column.
  Mobile: single column; blocks render in section.blocks drag order (CSS order).
  Announcement is a regular block that lives in a column like every other block.
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

<section class="nh-spotlight" id="nh-section-{{ section.id }}">
  <div class="nh-spotlight-grid">
    <div class="nh-spotlight-col nh-spotlight-col--left">
      {%- for block in section.blocks -%}
        {%- assign _col = block.settings.column | default: 'left' -%}
        {%- if _col != 'right' -%}
          {%- render 'nh-spotlight-block', block: block, section_settings: section.settings, order: forloop.index0 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="nh-spotlight-col nh-spotlight-col--right">
      {%- for block in section.blocks -%}
        {%- assign _col = block.settings.column | default: 'left' -%}
        {%- if _col == 'right' -%}
          {%- render 'nh-spotlight-block', block: block, section_settings: section.settings, order: forloop.index0 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NH - Spotlight",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section Colors (inherited by blocks)"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Default Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Default Accent Color",
      "default": "#cc0019"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement Bar",
      "limit": 2,
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "align",
          "label": "Alignment",
          "options": [
            { "value": "flex-start", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Right" }
          ],
          "default": "center"
        },
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "⚡" },
        { "type": "text", "id": "text", "label": "Text", "default": "LIMITED TIME OFFER: GET 1 MONTH FREE" },
        { "type": "color", "id": "bg_color", "label": "Background", "default": "#1a1a1a" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#fffbd5" },
        { "type": "range", "id": "font_size", "label": "Font Size (Desktop)", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 12 },
        { "type": "range", "id": "font_size_mobile", "label": "Font Size (Mobile)", "min": 9, "max": 18, "step": 1, "unit": "px", "default": 11 },
        { "type": "header", "content": "Visibility" },
        { "type": "checkbox", "id": "hide_mobile", "label": "Hide on Mobile", "default": false },
        { "type": "checkbox", "id": "hide_desktop", "label": "Hide on Desktop", "default": false }
      ]
    },
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "HERE'S WHY" },
        { "type": "color", "id": "color", "label": "Color (blank = section accent)" },
        { "type": "range", "id": "font_size", "label": "Font Size (Desktop)", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 13 },
        { "type": "range", "id": "font_size_mobile", "label": "Font Size (Mobile)", "min": 8, "max": 20, "step": 1, "unit": "px", "default": 12 },
        { "type": "range", "id": "letter_spacing", "label": "Letter Spacing (×0.01em)", "min": 0, "max": 40, "step": 5, "default": 20 },
        { "type": "header", "content": "Visibility" },
        { "type": "checkbox", "id": "hide_mobile", "label": "Hide on Mobile", "default": false },
        { "type": "checkbox", "id": "hide_desktop", "label": "Hide on Desktop", "default": false }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
