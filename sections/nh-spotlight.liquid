        "cta": { "type": "cta", "settings": { "column": "left" } },
        "reviews": { "type": "reviews", "settings": { "column": "left" } },
        "quote": { "type": "quote", "settings": { "column": "left" } }
      },
      "block_order": ["announce", "eyebrow", "heading", "pills", "image", "cta", "reviews", "quote"]
    }
  ]
}
{% endschema %}
