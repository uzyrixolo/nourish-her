      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "LIMITED TIME OFFER: GET 1 MONTH FREE"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background",
          "default": "#1a1a1a"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
