          "default": "left"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "HERE'S WHY" },
        { "type": "color", "id": "color", "label": "Color (blank = section accent)" },
        { "type": "range", "id": "font_size", "label": "Font Size (Desktop)", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 13 },
        { "type": "range", "id": "font_size_mobile", "label": "Font Size (Mobile)", "min": 8, "max": 20, "step": 1, "unit": "px", "default": 12 },
        { "type": "range", "id": "letter_spacing", "label": "Letter Spacing", "min": 0, "max": 0.4, "step": 0.01, "unit": "em", "default": 0.18 },
        { "type": "header", "content": "Visibility" },
        { "type": "checkbox", "id": "hide_mobile", "label": "Hide on Mobile", "default": false },
        { "type": "checkbox", "id": "hide_desktop", "label": "Hide on Desktop", "default": false }
      ]
    },
    {
