    },
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
