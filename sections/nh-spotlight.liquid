        { "type": "range", "id": "font_size", "label": "Font Size (Desktop)", "min": 18, "max": 64, "step": 1, "unit": "px", "default": 38 },
        { "type": "range", "id": "font_size_mobile", "label": "Font Size (Mobile)", "min": 16, "max": 48, "step": 1, "unit": "px", "default": 28 },
        { "type": "header", "content": "Visibility" },
        { "type": "checkbox", "id": "hide_mobile", "label": "Hide on Mobile", "default": false },
        { "type": "checkbox", "id": "hide_desktop", "label": "Hide on Desktop", "default": false }
      ]
    },
    {
      "type": "pills",
