  ],
  "presets": [
    {
      "name": "NH - Spotlight",
      "blocks": {
        "announce": { "type": "announcement" },
        "eyebrow": { "type": "eyebrow", "settings": { "column": "left" } },
        "heading": { "type": "heading", "settings": { "column": "left" } },
        "pills": { "type": "pills", "settings": { "column": "left" } },
