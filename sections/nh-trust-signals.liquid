{% comment %}
  Nourish Her - Trust Signals Bar
  Horizontal trust badges bar
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-trust-badge-label {
    color: {{ section.settings.text_color }};
  }
{% endstyle %}

<section class="nh-trust-section" id="nh-section-{{ section.id }}">
  <div class="nh-trust-inner">
    {% for block in section.blocks %}
      <div class="nh-trust-badge" {{ block.shopify_attributes }}>
        <div class="nh-trust-badge-icon">
          {% if block.settings.custom_image != blank %}
            {{ block.settings.custom_image | image_url: width: 40 | image_tag: alt: block.settings.label, loading: 'lazy', class: 'nh-trust-custom-img' }}
          {% else %}
            {{ block.settings.icon }}
          {% endif %}
        </div>
        <div class="nh-trust-badge-label">{{ block.settings.label }}</div>
      </div>
    {% endfor %}
    {% comment %} Duplicate for mobile carousel {% endcomment %}
    {% for block in section.blocks %}
      <div class="nh-trust-badge">
        <div class="nh-trust-badge-icon">
          {% if block.settings.custom_image != blank %}
            {{ block.settings.custom_image | image_url: width: 40 | image_tag: alt: block.settings.label, loading: 'lazy', class: 'nh-trust-custom-img' }}
          {% else %}
            {{ block.settings.icon }}
          {% endif %}
        </div>
        <div class="nh-trust-badge-label">{{ block.settings.label }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "NH - Trust Signals",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#444444"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (SVG/PNG)",
          "info": "Overrides the emoji if selected"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "🛡️"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "30-Day Money-Back Guarantee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Trust Signals",
      "blocks": {
        "badge_1": {
          "type": "trust_badge",
          "settings": {
            "icon": "🛡️",
            "label": "30-Day Money-Back Guarantee"
          }
        },
        "badge_2": {
          "type": "trust_badge",
          "settings": {
            "icon": "🌿",
            "label": "Non-GMO"
          }
        },
        "badge_3": {
          "type": "trust_badge",
          "settings": {
            "icon": "🐄",
            "label": "100% Grass-Fed"
          }
        },
        "badge_4": {
          "type": "trust_badge",
          "settings": {
            "icon": "🌾",
            "label": "Gluten-Free"
          }
        },
        "badge_5": {
          "type": "trust_badge",
          "settings": {
            "icon": "🔬",
            "label": "Lab Tested"
          }
        },
        "badge_6": {
          "type": "trust_badge",
          "settings": {
            "icon": "🇳🇿",
            "label": "New Zealand Sourced"
          }
        }
      },
      "block_order": ["badge_1", "badge_2", "badge_3", "badge_4", "badge_5", "badge_6"]
    }
  ]
}
{% endschema %}
