{% comment %}
  Nourish Her - Announcement Bar (Marquee)
  Scrolling announcement bar with brand messaging
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

<div class="nh-announcement-bar" aria-label="Announcement">
  <div class="nh-marquee-inner">
    {% for block in section.blocks %}
      <span>{{ block.settings.text }}</span>
    {% endfor %}
    {% comment %} Duplicate for seamless loop {% endcomment %}
    {% for block in section.blocks %}
      <span>{{ block.settings.text }}</span>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "NH - Announcement Bar",
  "tag": "section",
  "class": "nh-section-wrapper",
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "🌿 100% Grass-Fed & Pasture Raised"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Announcement Bar",
      "blocks": {
        "announcement_1": {
          "type": "announcement",
          "settings": {
            "text": "🌿 100% Grass-Fed & Pasture Raised"
          }
        },
        "announcement_2": {
          "type": "announcement",
          "settings": {
            "text": "✦ Free UK Shipping on Orders Over £50"
          }
        },
        "announcement_3": {
          "type": "announcement",
          "settings": {
            "text": "🔬 Third-Party Lab Tested"
          }
        },
        "announcement_4": {
          "type": "announcement",
          "settings": {
            "text": "💊 Whole-Food Nutrition for Women"
          }
        }
      },
      "block_order": ["announcement_1", "announcement_2", "announcement_3", "announcement_4"]
    }
  ]
}
{% endschema %}
