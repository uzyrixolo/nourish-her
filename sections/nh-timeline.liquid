{% comment %}
  Nourish Her - Timeline Section
  Journey of benefits over months
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-timeline-disclaimer {
    color: {{ section.settings.text_color }};
  }
  #nh-section-{{ section.id }} .nh-timeline-dot {
    background: {{ section.settings.accent_color }};
    box-shadow: 0 0 0 3px {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-timeline-month {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-timeline-content {
    background: {{ section.settings.card_bg }};
    border-color: {{ section.settings.card_border }};
  }
  #nh-section-{{ section.id }} .nh-timeline-content h3 {
    color: {{ section.settings.card_text_title }};
  }
  #nh-section-{{ section.id }} .nh-timeline-content p {
    color: {{ section.settings.card_text_body }};
  }
  #nh-section-{{ section.id }} .nh-timeline::before {
    background: linear-gradient(to bottom, {{ section.settings.accent_color | color_modify: 'alpha', 0.15 }}, {{ section.settings.accent_color | color_modify: 'alpha', 0.08 }});
  }
  #nh-section-{{ section.id }} .nh-timeline::after {
    background: linear-gradient(to bottom, {{ section.settings.accent_color }}, {{ section.settings.accent_color | color_modify: 'alpha', 0.5 }});
  }
{% endstyle %}

<section class="nh-section nh-timeline-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.disclaimer != blank %}
      <p class="nh-timeline-disclaimer">{{ section.settings.disclaimer }}</p>
    {% endif %}
    
    {% if section.blocks.size > 0 %}
      <div class="nh-timeline">
        {% for block in section.blocks %}
          <div class="nh-timeline-item" {{ block.shopify_attributes }}>
            <div class="nh-timeline-month">{{ block.settings.month }}</div>
            <div class="nh-timeline-dot"></div>
            <div class="nh-timeline-content">
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.description }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('nh-section-{{ section.id }}');
    if (!section) return;

    var timeline = section.querySelector('.nh-timeline');
    var items = section.querySelectorAll('.nh-timeline-item');
    if (!timeline || !items.length) return;

    function updateProgress() {
      var lastVisible = null;
      for (var i = 0; i < items.length; i++) {
        if (items[i].classList.contains('nh-in-view')) lastVisible = items[i];
      }
      if (lastVisible && timeline) {
        var tRect = timeline.getBoundingClientRect();
        var iRect = lastVisible.getBoundingClientRect();
        var dot = lastVisible.querySelector('.nh-timeline-dot');
        var target = dot ? dot.getBoundingClientRect().top + dot.offsetHeight / 2 - tRect.top : iRect.top + 40 - tRect.top;
        timeline.style.setProperty('--nh-tl-progress', Math.max(0, target) + 'px');
      }
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('nh-in-view');
          updateProgress();
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -60px 0px'
    });

    items.forEach(function(item) {
      observer.observe(item);
    });
  })();
</script>

