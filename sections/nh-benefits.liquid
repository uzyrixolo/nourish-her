{% comment %}
  Nourish Her - Benefits Section
  Four pillars of female vitality
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-benefit-card {
    background: {{ section.settings.card_bg }};
    border-color: {{ section.settings.card_border }};
  }
  #nh-section-{{ section.id }} .nh-benefit-card h3 {
    color: {{ section.settings.card_text_title }};
  }
  #nh-section-{{ section.id }} .nh-benefit-card p {
    color: {{ section.settings.card_text_body }};
  }
  #nh-section-{{ section.id }} .nh-benefit-icon {
    background: {{ section.settings.card_icon_bg }};
    color: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section class="nh-section nh-benefits-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    {% if section.blocks.size > 0 %}
      <div class="nh-benefits-grid">
        {% for block in section.blocks %}
          <div class="nh-benefit-card" {{ block.shopify_attributes }}>
            <div class="nh-benefit-icon">
              {% if block.settings.custom_image != blank %}
                {{ block.settings.custom_image | image_url: width: 64 | image_tag: alt: block.settings.title, loading: 'lazy', class: 'nh-benefit-custom-img' }}
              {% else %}
                {{ block.settings.icon }}
              {% endif %}
            </div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "NH - Benefits",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#fdf8f0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#fe3c93"
    },
    {
      "type": "header",
      "content": "Card Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card Border",
      "default": "#ffd4e2"
    },
    {
      "type": "color",
      "id": "card_text_title",
      "label": "Card Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "card_text_body",
      "label": "Card Body Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "card_icon_bg",
      "label": "Icon Background",
      "default": "#fdf8f0"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "What You'll Feel"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Four Pillars of <em>Female Vitality</em></p>"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (SVG/PNG)",
          "info": "Overrides the emoji if selected"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Sustained Energy"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Bioavailable haem iron, B12, and B-vitamins support normal energy-yielding metabolism — no crashes, no stimulants."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NH - Benefits",
      "blocks": {
        "benefit_1": {
          "type": "benefit",
          "settings": {
            "icon": "⚡",
            "title": "Sustained Energy",
            "description": "Bioavailable haem iron, B12, and B-vitamins support normal energy-yielding metabolism — no crashes, no stimulants."
          }
        },
        "benefit_2": {
          "type": "benefit",
          "settings": {
            "icon": "🌸",
            "title": "Hormone Support",
            "description": "Whole-food micronutrients help replenish nutrient stores and support normal hormonal and metabolic function over time."
          }
        },
        "benefit_3": {
          "type": "benefit",
          "settings": {
            "icon": "✨",
            "title": "Skin & Hair Health",
            "description": "Vitamin A, zinc, and copper support normal skin cell turnover, connective tissue health, and hair vitality."
          }
        },
        "benefit_4": {
          "type": "benefit",
          "settings": {
            "icon": "🧠",
            "title": "Mental Clarity",
            "description": "Iron, B12, and copper support red blood cell formation and oxygen delivery — helping to lift the fog and sharpen focus."
          }
        }
      },
      "block_order": ["benefit_1", "benefit_2", "benefit_3", "benefit_4"]
    }
  ]
}
{% endschema %}
