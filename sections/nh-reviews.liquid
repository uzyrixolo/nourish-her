{% comment %}
  Nourish Her - Reviews Carousel
  Infinite scrolling social proof
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-review-card {
    background: {{ section.settings.card_bg }};
    border-color: {{ section.settings.card_border }};
    color: {{ section.settings.card_text }};
  }
  #nh-section-{{ section.id }} .nh-review-stars {
    color: {{ section.settings.star_color }};
  }
  #nh-section-{{ section.id }} .nh-review-text {
    color: {{ section.settings.card_text }};
  }
  #nh-section-{{ section.id }} .nh-reviewer-name {
    color: {{ section.settings.card_text }};
  }
  #nh-section-{{ section.id }} .nh-reviewer-avatar {
    background: {{ section.settings.accent_color | color_modify: 'alpha', 0.1 }};
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-reviewer-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  #nh-section-{{ section.id }} .nh-reviewer-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
{% endstyle %}

<section class="nh-section nh-reviews-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
  </div>
  
  {% if section.blocks.size > 0 %}
    <div class="nh-reviews-track-wrap">
      <div class="nh-reviews-track" id="nhReviewsTrack-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="nh-review-card" {{ block.shopify_attributes }}>
            <div class="nh-review-stars">{{ block.settings.stars }}</div>
            <p class="nh-review-text">"{{ block.settings.review }}"</p>
            <div class="nh-reviewer">
              {% if block.settings.reviewer_image != blank %}
                <div class="nh-reviewer-avatar">{{ block.settings.reviewer_image | image_url: width: 100 | image_tag: alt: block.settings.name, loading: 'lazy' }}</div>
              {% else %}
                <div class="nh-reviewer-avatar">{{ block.settings.name | slice: 0 }}</div>
              {% endif %}
              <div>
                <div class="nh-reviewer-name">{{ block.settings.name }}</div>
                <div class="nh-reviewer-tag">{{ block.settings.tag }}</div>
                {% if block.settings.verified %}
                  <div class="nh-verified-badge">✓ Verified</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
        {% comment %} Duplicate for seamless loop {% endcomment %}
        {% for block in section.blocks %}
          <div class="nh-review-card">
            <div class="nh-review-stars">{{ block.settings.stars }}</div>
            <p class="nh-review-text">"{{ block.settings.review }}"</p>
            <div class="nh-reviewer">
              {% if block.settings.reviewer_image != blank %}
                <div class="nh-reviewer-avatar">{{ block.settings.reviewer_image | image_url: width: 100 | image_tag: alt: block.settings.name, loading: 'lazy' }}</div>
              {% else %}
                <div class="nh-reviewer-avatar">{{ block.settings.name | slice: 0 }}</div>
              {% endif %}
              <div>
                <div class="nh-reviewer-name">{{ block.settings.name }}</div>
                <div class="nh-reviewer-tag">{{ block.settings.tag }}</div>
                {% if block.settings.verified %}
                  <div class="nh-verified-badge">✓ Verified</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var track = document.getElementById('nhReviewsTrack-' + sectionId);
    if (!track) return;
    var wrap = track.parentElement;
    if (!wrap) return;

    var mq = window.matchMedia('(max-width: 768px)');
    var PX_PER_SEC = 40;             /* matches desktop CSS animation speed */
    var IDLE_AFTER_INPUT_MS = 500;   /* short idle after release so resume feels quick */

    /* Mobile motion model: we own the X position fully via translate3d.
       virtualX is a float, so we get sub-pixel-smooth GPU motion every frame. */
    var virtualX = 0;
    var lastTs = 0;
    var isTouching = false;
    var lastUserInput = 0;

    /* Swipe state */
    var startTouchX = 0;
    var startTouchY = 0;
    var startVirtualX = 0;
    var direction = null;            /* 'h' | 'v' | null until detected */

    function cycleWidth() {
      /* Track contains [originals][duplicates]; one cycle is half the total width. */
      return track.scrollWidth / 2;
    }

    function applyTransform() {
      track.style.transform = 'translate3d(' + (-virtualX).toFixed(2) + 'px, 0, 0)';
    }

    function wrapVirtual() {
      var c = cycleWidth();
      if (c <= 0) return;
      if (virtualX >= c) virtualX -= c;
      else if (virtualX < 0) virtualX += c;
    }

    function onTouchStart(e) {
      if (!mq.matches) return;
      var t = e.touches[0];
      startTouchX = t.clientX;
      startTouchY = t.clientY;
      startVirtualX = virtualX;
      direction = null;
      isTouching = true;
      lastUserInput = performance.now();
    }

    function onTouchMove(e) {
      if (!mq.matches || !isTouching) return;
      var t = e.touches[0];
      var dx = t.clientX - startTouchX;
      var dy = t.clientY - startTouchY;
      if (direction === null) {
        var ax = Math.abs(dx), ay = Math.abs(dy);
        if (ax < 6 && ay < 6) return;     /* below detection threshold */
        direction = ax > ay ? 'h' : 'v';
      }
      if (direction === 'h') {
        virtualX = startVirtualX - dx;
        wrapVirtual();
        applyTransform();
        lastUserInput = performance.now();
      }
      /* If 'v', do nothing — touch-action: pan-y lets the page scroll vertically. */
    }

    function onTouchEnd() {
      if (!mq.matches) return;
      isTouching = false;
      direction = null;
      lastUserInput = performance.now();
      lastTs = 0;
    }

    wrap.addEventListener('touchstart',  onTouchStart, { passive: true });
    wrap.addEventListener('touchmove',   onTouchMove,  { passive: true });
    wrap.addEventListener('touchend',    onTouchEnd,   { passive: true });
    wrap.addEventListener('touchcancel', onTouchEnd,   { passive: true });
    /* Pointer events for stylus / desktop dev tools mobile emulation */
    wrap.addEventListener('pointerdown', function () { lastUserInput = performance.now(); }, { passive: true });

    function tick(ts) {
      if (mq.matches) {
        var paused = isTouching
                  || (lastUserInput && (performance.now() - lastUserInput < IDLE_AFTER_INPUT_MS));
        if (!paused) {
          var dt = lastTs ? (ts - lastTs) / 1000 : 0;
          if (dt > 0.1) dt = 0.1;
          virtualX += PX_PER_SEC * dt;
          wrapVirtual();
          applyTransform();
        }
      } else {
        /* Desktop: hand control back to the CSS keyframe animation by clearing inline transform. */
        if (track.style.transform) track.style.transform = '';
      }
      lastTs = ts;
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  })();
</script>

{% schema %}
{
