{% comment %}
  Nourish Her - FAQ Section
  Accordion-style frequently asked questions
{% endcomment %}

{{ 'nourish-her.css' | asset_url | stylesheet_tag }}

{% style %}
  #nh-section-{{ section.id }} {
    {% if section.settings.bg_color != blank %}background: {{ section.settings.bg_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    #nh-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    }
  }
  #nh-section-{{ section.id }} .nh-section-title {
    color: {{ section.settings.heading_color }};
  }
  #nh-section-{{ section.id }} .nh-section-label {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-divider {
    background: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-faq-question {
    color: {{ section.settings.question_color }};
    background: {{ section.settings.item_bg }};
    border-bottom-color: {{ section.settings.item_border }};
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }
  #nh-section-{{ section.id }} .nh-faq-answer {
    color: {{ section.settings.answer_color }};
    background: {{ section.settings.item_bg }};
  }
  #nh-section-{{ section.id }} .nh-faq-item.nh-open .nh-faq-question {
    color: {{ section.settings.accent_color }};
  }
  #nh-section-{{ section.id }} .nh-faq-icon {
    color: {{ section.settings.accent_color }};
  }
{% endstyle %}

<section class="nh-section nh-faq-section" id="nh-section-{{ section.id }}">
  <div class="nh-section-inner">
    {% if section.settings.label != blank %}
      <p class="nh-section-label">{{ section.settings.label }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="nh-section-title">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="nh-divider"></div>
    
    {% if section.blocks.size > 0 %}
      <div class="nh-faq-list">
        {% for block in section.blocks %}
          <div class="nh-faq-item" {{ block.shopify_attributes }}>
            <button class="nh-faq-question" onclick="nhToggleFaq(this)">
              {{ block.settings.question }}
              <div class="nh-faq-icon">+</div>
            </button>
            <div class="nh-faq-answer">
              <p>{{ block.settings.answer }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<script>
  function nhToggleFaq(btn) {
    const item = btn.closest('.nh-faq-item');
    const isOpen = item.classList.contains('nh-open');
    document.querySelectorAll('.nh-faq-item.nh-open').forEach(el => el.classList.remove('nh-open'));
    if (!isOpen) item.classList.add('nh-open');
  }
</script>

{% schema %}
{
  "name": "NH - FAQ",
  "tag": "section",
  "class": "nh-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom Padding (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
