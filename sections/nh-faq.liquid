      "default": "#cc0019"
    },
    {
      "type": "header",
      "content": "Item Colors"
    },
    {
      "type": "color",
      "id": "item_bg",
      "label": "Item Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "item_border",
