    "nh-faq": {
      "type": "nh-faq",
      "settings": {},
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "What exactly is in Nourish Her\u2122?",
            "answer": "Nourish Her\u2122 contains six 100% grass-fed beef organs: liver, spleen, kidney, heart, uterus, and ovaries. Each organ is sourced from pasture-raised cattle in New Zealand, gently freeze-dried to preserve nutrients, and encapsulated with no fillers, binders, or synthetic additives."
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "How many capsules do I take per day?",
            "answer": "We recommend taking 3 capsules per day with food. Each pouch contains 90 capsules \u2014 a full 30-day supply at the recommended serving size."
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Will I taste or smell the organs?",
            "answer": "No. The organs are gently freeze-dried and encapsulated, which neutralises any taste or odour entirely. This is one of the key reasons we created Nourish Her\u2122 \u2014 to make organ nutrition accessible without having to eat raw or cooked organs."
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Is Nourish Her\u2122 suitable for pregnant or breastfeeding women?",
            "answer": "Beef liver is very high in vitamin A (retinol). While this is a benefit for most women, high doses of preformed vitamin A are not recommended during pregnancy. We advise pregnant or breastfeeding women to consult their healthcare provider before taking Nourish Her\u2122."
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "How long before I notice results?",
            "answer": "Most women report noticing steadier energy levels within the first 2\u20134 weeks. More significant changes \u2014 such as improved skin, hair, and hormonal balance \u2014 are typically observed after 2\u20133 months of consistent daily use. Results vary depending on your individual nutrient status and lifestyle."
          }
        },
        "faq_6": {
          "type": "faq_item",
          "settings": {
            "question": "Can I cancel my subscription at any time?",
            "answer": "Yes, absolutely. You can cancel, pause, or modify your subscription at any time through your account portal \u2014 no fees, no awkward phone calls. We want you to stay because you love the product, not because you're locked in."
          }
        },
        "faq_7": {
          "type": "faq_item",
          "settings": {
            "question": "What is your returns policy?",
            "answer": "We offer a 30-day money-back guarantee. If you're not satisfied for any reason within 30 days of purchase, simply contact us and we'll issue a full refund \u2014 no questions asked."
          }
        },
        "faq_8": {
          "type": "faq_item",
          "settings": {
            "question": "Is Nourish Her\u2122 gluten-free and non-GMO?",
            "answer": "Yes. Nourish Her\u2122 is 100% gluten-free, non-GMO, and free from artificial additives, fillers, and binders. It is a pure, whole-food supplement with nothing unnecessary added."
          }
        }
      },
