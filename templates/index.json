      "blocks": {
        "review_1": {
          "type": "review",
          "settings": {
            "stars": "\u2605\u2605\u2605\u2605\u2605",
            "review": "I've tried so many supplements and nothing has come close. Within the first few weeks I noticed my energy was steadier \u2014 no more 3pm crash. My skin has genuinely never looked better.",
            "name": "Sarah M.",
            "tag": "Verified Customer",
            "verified": true
          }
        },
        "review_2": {
          "type": "review",
          "settings": {
            "stars": "\u2605\u2605\u2605\u2605\u2605",
            "review": "As a nurse working 12-hour shifts, I was constantly running on empty. After two months on Nourish Her, I genuinely feel like myself again. My iron levels improved and my focus is back.",
            "name": "Emma L.",
            "tag": "Verified Customer",
            "verified": true
          }
        },
        "review_3": {
          "type": "review",
          "settings": {
            "stars": "\u2605\u2605\u2605\u2605\u2605",
            "review": "I was sceptical about organ supplements but the science behind this is undeniable. Three months in and my hair is thicker, my hormones feel balanced, and I've ditched my old multivitamin for good.",
            "name": "Rachel T.",
            "tag": "Verified Customer",
            "verified": true
          }
        },
        "review_4": {
          "type": "review",
          "settings": {
            "stars": "\u2605\u2605\u2605\u2605\u2605",
            "review": "Finally a supplement that was made with women in mind. The fact that it includes uterus and ovaries is something no other brand does. I feel more balanced and less fatigued during my cycle.",
            "name": "Amara K.",
            "tag": "Verified Customer",
            "verified": true
          }
        }
      },
      "block_order": [
        "review_1",
        "review_2",
        "review_3",
        "review_4"
      ]
